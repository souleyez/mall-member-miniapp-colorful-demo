<view class="demo-page theme-pop {{currentView !== 'home' ? 'theme-light theme-inner-soft' : ''}} view-{{currentView}}">
  <view class="screen {{leaving ? 'screen-leave' : 'screen-enter'}} {{showBottom ? 'screen-with-bottom' : ''}}">
    <block wx:if="{{currentView !== 'home'}}">
      <view class="nav-safe" style="height: {{statusBarHeight}}px"></view>
      <view class="nav-bar">
        <view class="nav-back tap-target" hover-class="tap-press" bindtap="goBack">‹</view>
        <text class="nav-title">{{viewTitle}}</text>
      </view>
    </block>

    <!-- 1 探索首页 -->
    <block wx:if="{{currentView === 'home'}}">
      <view class="home-hero pop-home-hero pop-home-hero-{{homeConfig.bannerTone}} {{homeRefreshing ? 'home-refreshing' : ''}}">
        <view class="nav-safe" style="height: {{statusBarHeight}}px"></view>
        <view class="home-nav">
          <view class="mall-pill tap-target" hover-class="tap-press" bindtap="openMallSheet">
            <text class="pop-location-dot">●</text><text>{{mallName}}</text><text class="chevron-down">⌄</text>
          </view>
        </view>
    <swiper class="pop-hero-swiper" current="{{heroCurrent}}" circular duration="420" bindchange="onHeroChange">
          <swiper-item wx:for="{{homeConfig.heroSlides}}" wx:key="id" wx:for-item="heroSlide" wx:for-index="heroIndex">
            <view class="pop-hero-poster pop-hero-poster-{{heroSlide.tone}} tap-target" hover-class="tap-press" data-id="{{heroSlide.activityId}}" bindtap="openHeroSlide">
              <view class="pop-paper-edge"></view>
              <image class="pop-hero-scene" src="{{heroSlide.image}}" mode="widthFix" />
              <text class="pop-doodle pop-doodle-star">★</text><text class="pop-doodle pop-doodle-sun">☀</text><text class="pop-doodle pop-doodle-wave">〰</text>
              <view class="pop-hero-copy"><text class="pop-hero-kicker">{{heroSlide.eyebrow}}</text><text class="pop-hero-title">{{heroSlide.title}}</text><text class="pop-hero-ribbon">{{heroSlide.ribbon}}</text><text class="pop-hero-date">{{heroSlide.date}}</text></view>
              <view class="pop-door"><view></view><text>GO</text></view><view class="pop-runner">↗</view>
              <view class="pop-hero-action">{{heroSlide.action}} <text>→</text></view>
            </view>
          </swiper-item>
        </swiper>
        <view class="pop-hero-dots"><text wx:for="{{homeConfig.heroSlides}}" wx:key="id" wx:for-item="heroDot" wx:for-index="heroDotIndex" class="{{heroDotIndex === heroCurrent ? 'active' : ''}}"></text></view>
      </view>

      <view class="home-body {{homeRefreshing ? 'home-refreshing' : ''}}">
        <view wx:if="{{homeConfig.couponShowcaseAboveServices && availableCouponCount > 0}}" class="home-coupon-showcase">
          <view class="home-coupon-showcase-head">
            <view><text>今日好券</text><text>先领券，再开启城市漫游</text></view>
            <view class="tap-target" hover-class="tap-press" data-target="coupons" bindtap="navigate">全部好券 ›</view>
          </view>
          <scroll-view class="home-coupon-showcase-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
            <view class="home-coupon-showcase-track">
              <view wx:for="{{availableCoupons}}" wx:key="id" wx:for-item="coupon" wx:for-index="couponIndex" class="home-coupon-mini home-coupon-mini-{{couponIndex}} tap-target" hover-class="tap-press" data-source="available" data-index="{{couponIndex}}" bindtap="openCoupon">
                <view class="home-coupon-mini-top"><text>{{coupon.method}}</text><text>COUPON</text></view>
                <text class="home-coupon-mini-title">{{coupon.title}}</text>
                <text class="home-coupon-mini-note">{{coupon.note}}</text>
                <view class="home-coupon-mini-bottom"><text>{{coupon.cta}}</text><text>领取 ›</text></view>
              </view>
            </view>
          </scroll-view>
        </view>

        <view class="home-play-zone">
          <view class="home-play-head"><view><text>会员乐园</text><text>常用服务一站直达</text></view><text>8 SERVICES</text></view>
          <view wx:if="{{homeConfig.memberPosition === 'services'}}" class="member-summary pop-member-strip member-theme-{{homeConfig.memberTheme}} tap-target" hover-class="tap-press" data-target="card" bindtap="navigate">
            <view class="pop-member-avatar">{{homeConfig.memberMark}}</view>
            <view class="member-copy"><text class="member-name"><text class="member-name-key">{{homeConfig.memberName}}</text><text class="member-name-suffix">会员</text></text><text class="member-sub">我的艺享积分 <text class="gold-number">{{points}}</text></text></view>
            <view class="pop-member-arrow">→</view>
          </view>
          <view class="shortcut-row pop-shortcut-grid">
            <view class="shortcut pop-shortcut tone-yellow tap-target" hover-class="tap-press" data-target="points" bindtap="navigate"><view class="pop-line-icon"><image class="pop-line-icon-image" src="/assets/icons/pop/points.png" mode="aspectFit" /></view><text class="shortcut-label">积分中心</text></view>
            <view class="shortcut pop-shortcut tone-pink tap-target" hover-class="tap-press" data-target="coupons" bindtap="navigate"><view class="pop-line-icon"><image class="pop-line-icon-image" src="/assets/icons/pop/coupons.png" mode="aspectFit" /></view><text class="shortcut-label">卡券包</text></view>
            <view class="shortcut pop-shortcut tone-blue tap-target" hover-class="tap-press" data-target="parking" bindtap="navigate"><view class="pop-line-icon"><image class="pop-line-icon-image" src="/assets/icons/pop/parking.png" mode="aspectFit" /></view><text class="shortcut-label">停车缴费</text></view>
            <view class="shortcut pop-shortcut tone-violet tap-target" hover-class="tap-press" data-target="service" bindtap="navigate"><view class="pop-line-icon"><image class="pop-line-icon-image" src="/assets/icons/pop/service.png" mode="aspectFit" /></view><text class="shortcut-label">商场服务</text></view>
            <view class="shortcut pop-shortcut tone-mint tap-target" hover-class="tap-press" data-target="activityList" bindtap="navigate"><view class="pop-line-icon"><image class="pop-line-icon-image" src="/assets/icons/pop/activity.png" mode="aspectFit" /></view><text class="shortcut-label">活动日历</text></view>
            <view class="shortcut pop-shortcut tone-yellow tap-target" hover-class="tap-press" data-target="mall" bindtap="navigate"><view class="pop-line-icon"><image class="pop-line-icon-image" src="/assets/icons/pop/mall.png" mode="aspectFit" /></view><text class="shortcut-label">礼遇商城</text></view>
            <view class="shortcut pop-shortcut tone-pink tap-target" hover-class="tap-press" data-target="card" bindtap="navigate"><view class="pop-line-icon"><image class="pop-line-icon-image" src="/assets/icons/pop/member-card.png" mode="aspectFit" /></view><text class="shortcut-label">会员卡</text></view>
            <view class="shortcut pop-shortcut tone-blue tap-target" hover-class="tap-press" data-target="customerService" bindtap="navigate"><view class="pop-line-icon"><image class="pop-line-icon-image" src="/assets/icons/pop/customer-service.png" mode="aspectFit" /></view><text class="shortcut-label">联系我们</text></view>
          </view>
        </view>

        <block wx:for="{{homeConfig.layout}}" wx:key="*this" wx:for-item="homeModule">
          <view wx:if="{{homeModule === 'coupon' && availableCouponCount > 0}}" class="home-coupon-teaser home-module tap-target" hover-class="tap-press" data-source="available" data-index="0" bindtap="openCoupon">
            <image class="home-coupon-image" src="/assets/images/pop-home/coffee-lifestyle.jpg" mode="aspectFill" />
            <view class="home-coupon-copy">
              <view class="home-coupon-meta"><text class="home-coupon-badge">可领取</text><text>{{availableCoupons[0].method}}</text></view>
              <text class="home-coupon-title">{{availableCoupons[0].title}}</text>
              <text class="home-coupon-note">{{availableCoupons[0].note}}</text>
            </view>
            <view class="home-coupon-action"><text>领取</text><text class="home-coupon-arrow">›</text></view>
          </view>

          <view wx:if="{{homeModule === 'banner'}}" class="activity-banner activity-banner-{{homeConfig.bannerTone}} home-module tap-target" hover-class="tap-press" data-target="activityList" bindtap="navigate">
            <image class="activity-banner-image" src="{{homeConfig.bannerImage}}" mode="aspectFit" />
            <view class="activity-banner-shade"></view>
            <view class="activity-banner-copy"><text class="activity-banner-kicker">{{homeConfig.bannerKicker}}</text><text class="activity-banner-title">{{homeConfig.bannerTitle}}</text><text class="activity-banner-note">{{homeConfig.bannerNote}}</text></view>
            <view class="activity-banner-arrow"><text>全部活动</text><text>›</text></view>
          </view>

          <view wx:if="{{homeModule === 'member'}}" class="member-summary pop-member-strip pop-member-strip-flow pop-member-strip-{{homeConfig.bannerTone}} member-theme-{{homeConfig.memberTheme}} home-module tap-target" hover-class="tap-press" data-target="card" bindtap="navigate">
            <view class="pop-member-avatar">{{homeConfig.memberMark}}</view>
            <view class="member-copy"><text class="member-name"><text class="member-name-key">{{homeConfig.memberName}}</text><text class="member-name-suffix">会员</text></text><text class="member-sub">我的艺享积分 <text class="gold-number">{{points}}</text></text></view>
            <view class="pop-member-arrow">→</view>
          </view>

          <view wx:if="{{homeModule === 'inspiration'}}" class="home-module">
            <view class="section-heading"><view><text class="section-title">{{homeConfig.inspirationTitle}}</text><text class="section-en">{{homeConfig.inspirationSub}}</text></view><view class="text-link tap-target" hover-class="tap-press" data-target="contentCenter" bindtap="navigate">查看全部 ›</view></view>
            <scroll-view class="inspiration-scroll" scroll-x enable-flex>
              <view wx:for="{{homeConfig.inspirations}}" wx:key="title" wx:for-item="inspiration" class="inspiration-card tap-target" hover-class="tap-press" data-id="{{inspiration.contentId}}" bindtap="openContent"><image class="thumb" src="{{inspiration.image}}" mode="aspectFill" /><text class="card-title">{{inspiration.title}}</text><text class="card-caption">{{inspiration.caption}}</text></view>
            </scroll-view>
          </view>
        </block>

        <view class="home-commerce-section">
          <view class="commerce-rail-head"><view><text class="commerce-rail-kicker">GROUP DEAL</text><text class="section-title">团购精选</text><text class="section-en">一起拼更划算 · 到店核销有保障</text></view><view class="text-link tap-target" hover-class="tap-press" data-target="groupBuy" bindtap="navigate">全部团购 ›</view></view>
          <scroll-view class="commerce-rail" scroll-x enable-flex show-scrollbar="false">
            <view wx:for="{{homeConfig.commerce.groupBuys}}" wx:key="id" wx:for-item="commerceItem" class="commerce-mini-card group tap-target" hover-class="tap-press" data-type="group" data-index="{{index}}" bindtap="openCommerceProduct">
              <view class="commerce-mini-visual"><image src="{{commerceItem.image}}" mode="aspectFill" /><text>{{commerceItem.badge}}</text></view>
              <view class="commerce-mini-copy"><text class="commerce-mini-store">{{commerceItem.store}}</text><text class="commerce-mini-name">{{commerceItem.name}}</text><text class="commerce-mini-spec">{{commerceItem.spec}}</text><view class="commerce-mini-price"><view><text>¥</text><text>{{commerceItem.price}}</text><text>¥{{commerceItem.originalPrice}}</text></view><text>{{commerceItem.sold}}</text></view></view>
            </view>
          </scroll-view>

          <view class="commerce-rail-head shop-head"><view><text class="commerce-rail-kicker">ONLINE SHOP</text><text class="section-title">在线商城</text><text class="section-en">商场精选好物 · 支持配送与到店自提</text></view><view class="text-link tap-target" hover-class="tap-press" data-target="onlineShop" bindtap="navigate">进入商城 ›</view></view>
          <scroll-view class="commerce-rail" scroll-x enable-flex show-scrollbar="false">
            <view wx:for="{{homeConfig.commerce.shopProducts}}" wx:key="id" wx:for-item="commerceItem" class="commerce-mini-card shop tap-target" hover-class="tap-press" data-type="shop" data-index="{{index}}" bindtap="openCommerceProduct">
              <view class="commerce-mini-visual"><image src="{{commerceItem.image}}" mode="aspectFill" /><text>{{commerceItem.badge}}</text></view>
              <view class="commerce-mini-copy"><text class="commerce-mini-store">{{commerceItem.store}}</text><text class="commerce-mini-name">{{commerceItem.name}}</text><text class="commerce-mini-spec">{{commerceItem.spec}}</text><view class="commerce-mini-price"><view><text>¥</text><text>{{commerceItem.price}}</text><text>¥{{commerceItem.originalPrice}}</text></view><text>{{commerceItem.sold}}</text></view></view>
            </view>
          </scroll-view>
        </view>

        <view class="waterfall-section">
          <view class="waterfall-heading"><view><text class="section-title">店铺优惠精选</text><text class="section-en">边逛边发现，更多优惠持续加载</text></view><text class="waterfall-count">已展示 {{homeFeedVisibleCount}}</text></view>
          <view class="waterfall-grid">
            <view class="waterfall-column">
              <view wx:for="{{homeFeedLeft}}" wx:key="title" wx:for-item="feedItem" class="waterfall-card waterfall-card-{{feedItem.kind}} tap-target" style="animation-delay: {{feedItem.delay}}ms" hover-class="tap-press" data-target="{{feedItem.target}}" bindtap="navigate">
                <view wx:if="{{feedItem.kind === 'coupon'}}" class="waterfall-coupon-visual coupon-tone-{{feedItem.tone}} {{feedItem.height}}"><text class="waterfall-coupon-mark">券</text><text class="waterfall-coupon-word">会员专享</text><text class="waterfall-coupon-cut">领</text></view>
                <view wx:if="{{feedItem.kind === 'invite'}}" class="waterfall-invite-visual {{feedItem.height}}"><text>邀</text><view><text>好友同行</text><text>+300 积分</text></view></view>
                <image wx:if="{{feedItem.kind === 'store'}}" class="waterfall-image {{feedItem.height}}" src="{{feedItem.image}}" mode="aspectFill" />
                <view class="waterfall-card-body"><text class="waterfall-label">{{feedItem.label}}</text><text class="waterfall-title">{{feedItem.title}}</text><text class="waterfall-caption">{{feedItem.caption}}</text><view class="waterfall-cta"><text>{{feedItem.kind === 'coupon' ? '立即领取' : (feedItem.kind === 'invite' ? '去邀请' : '进店看看')}}</text><text>›</text></view></view>
              </view>
            </view>
            <view class="waterfall-column">
              <view wx:for="{{homeFeedRight}}" wx:key="title" wx:for-item="feedItem" class="waterfall-card waterfall-card-{{feedItem.kind}} tap-target" style="animation-delay: {{feedItem.delay}}ms" hover-class="tap-press" data-target="{{feedItem.target}}" bindtap="navigate">
                <view wx:if="{{feedItem.kind === 'coupon'}}" class="waterfall-coupon-visual coupon-tone-{{feedItem.tone}} {{feedItem.height}}"><text class="waterfall-coupon-mark">券</text><text class="waterfall-coupon-word">会员专享</text><text class="waterfall-coupon-cut">领</text></view>
                <view wx:if="{{feedItem.kind === 'invite'}}" class="waterfall-invite-visual {{feedItem.height}}"><text>邀</text><view><text>好友同行</text><text>+300 积分</text></view></view>
                <image wx:if="{{feedItem.kind === 'store'}}" class="waterfall-image {{feedItem.height}}" src="{{feedItem.image}}" mode="aspectFill" />
                <view class="waterfall-card-body"><text class="waterfall-label">{{feedItem.label}}</text><text class="waterfall-title">{{feedItem.title}}</text><text class="waterfall-caption">{{feedItem.caption}}</text><view class="waterfall-cta"><text>{{feedItem.kind === 'coupon' ? '立即领取' : (feedItem.kind === 'invite' ? '去邀请' : '进店看看')}}</text><text>›</text></view></view>
              </view>
            </view>
          </view>
          <view wx:if="{{homeFeedLoading}}" class="waterfall-loading"><view></view><view></view><text>正在加载更多店铺优惠...</text></view>
          <view wx:else class="waterfall-more tap-target" hover-class="tap-press" bindtap="loadMoreHomeFeed"><text>{{homeFeedHasMore ? '继续逛逛，加载更多' : '更多店铺优惠即将上线'}}</text><text>{{homeFeedHasMore ? '⌄' : '·'}}</text></view>
        </view>

      </view>
    </block>

    <!-- 多商场聚合展示 -->
    <block wx:if="{{currentView === 'mallCollection'}}">
      <view class="content mall-collection-page">
        <view class="mall-collection-hero">
          <view class="mall-collection-orbit orbit-one"></view><view class="mall-collection-orbit orbit-two"></view>
          <text class="mall-collection-eyebrow">MULTI-MALL EXPERIENCE</text><text class="mall-collection-title">一座城市，多种灵感生活</text><text class="mall-collection-sub">聚合查看不同商场的活动、权益与到店服务</text>
          <view class="mall-collection-summary"><view><text>3</text><text>特色商场</text></view><view><text>19</text><text>本月活动</text></view><view><text>38</text><text>会员权益</text></view></view>
        </view>
        <view class="mall-collection-heading"><view><text class="section-title">发现商场</text><text class="section-en">每个空间，都有自己的城市表达</text></view><text>{{malls.length}} 个商场</text></view>
        <view wx:for="{{malls}}" wx:key="name" wx:for-item="mall" class="mall-showcase-card mall-showcase-{{mall.tone}} {{mall.name === selectedMallDetail ? 'mall-showcase-focus' : ''}}">
          <view class="mall-showcase-visual"><image src="{{mall.image}}" mode="aspectFill" /><view class="mall-showcase-shade"></view><view class="mall-showcase-top"><text>{{mall.eyebrow}}</text><text wx:if="{{mall.name === mallName}}">当前商场</text></view><view class="mall-showcase-copy"><view class="mall-showcase-mark">{{mall.initial}}</view><view><text>{{mall.name}}</text><text>{{mall.location}} · {{mall.distance}}</text></view></view></view>
          <view class="mall-showcase-body">
            <view class="mall-showcase-meta"><text>今日营业 {{mall.hours}}</text><view><text wx:for="{{mall.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text></view></view>
            <view class="mall-showcase-stats"><view wx:for="{{mall.stats}}" wx:key="label" wx:for-item="stat"><text>{{stat.value}}</text><text>{{stat.label}}</text></view></view>
            <view class="mall-showcase-event tap-target" hover-class="tap-press" data-target="activityList" bindtap="navigate"><view class="mall-showcase-event-icon">活</view><view><text>{{mall.eventTitle}}</text><text>{{mall.eventNote}}</text></view><text>›</text></view>
            <view class="mall-showcase-links"><view class="tap-target" hover-class="tap-press" data-target="coupons" bindtap="navigate"><text>券</text><view><text>会员权益</text><text>{{mall.benefit}}</text></view></view><view class="tap-target" hover-class="tap-press" data-target="service" bindtap="navigate"><text>服</text><view><text>到店服务</text><text>{{mall.service}}</text></view></view></view>
            <view class="mall-showcase-actions"><view class="mall-outline-action tap-target" hover-class="tap-press" data-target="guide" bindtap="navigate">查看导览</view><view class="mall-primary-action tap-target" hover-class="tap-press" data-mall="{{mall.name}}" bindtap="enterMallFromCollection">{{mall.name === mallName ? '进入当前首页' : '切换并进入'}}</view></view>
          </view>
        </view>
        <view class="mall-collection-end"><text></text><text>更多城市空间持续加入</text><text></text></view>
      </view>
    </block>

    <!-- 2 登录入会 -->
    <block wx:if="{{currentView === 'login'}}">
      <view class="content login-page">
        <view class="login-visual">
          <image class="material-image" src="/assets/images/pop-home/mall-guide.jpg" mode="aspectFill" />
          <view class="floating-card"><text class="floating-card-logo">艺享</text><text>MEMBER</text></view>
        </view>
        <text class="display-title">欢迎加入会员</text>
        <text class="display-sub">登录后享受积分、礼遇与专属服务</text>
        <button class="primary-button" hover-class="button-press" bindtap="loginSuccess">微信手机号快捷登录</button>
        <button class="secondary-button" hover-class="button-press" bindtap="loginSuccess">其他手机号登录</button>
        <view class="agreement tap-target" hover-class="tap-press" bindtap="toggleAgreement"><view class="check-dot {{agreementChecked ? 'checked' : ''}}">{{agreementChecked ? '✓' : ''}}</view><text>我已阅读并同意《会员服务协议》和《隐私政策》</text></view>
        <view class="muted-link tap-target" hover-class="tap-press" data-target="home" bindtap="switchBottom">暂不登录，先逛逛 ›</view>
      </view>
    </block>

    <!-- 3 会员卡 -->
    <block wx:if="{{currentView === 'card'}}">
      <view class="content">
        <view class="membership-card membership-card-{{homeConfig.memberTheme}} elevated-card">
          <image class="membership-card-art" src="{{homeConfig.heroImage}}" mode="aspectFill" />
          <view class="membership-card-shade"></view>
          <text class="membership-logo">{{homeConfig.memberEnglish}}</text>
          <text class="membership-level"><text class="member-name-key">{{homeConfig.memberName}}</text><text class="member-name-suffix">会员</text></text>
          <text class="membership-id">会员编号 8888 6688</text>
        </view>
        <view class="qr-panel soft-card">
          <text class="panel-title center">会员码</text>
          <view class="qr-code"><view wx:for="{{qrCells}}" wx:key="index" class="qr-cell {{item ? 'qr-dark' : ''}}"></view></view>
          <text class="microcopy">动态会员码，每60秒自动更新</text>
        </view>
        <view class="stats-card soft-card">
          <view class="stat"><text class="stat-label">艺享积分</text><text class="stat-value">{{points}}</text></view>
          <view class="stat-divider"></view>
          <view class="stat"><text class="stat-label">成长值</text><text class="stat-value">8,600</text></view>
        </view>
        <view class="dual-actions">
          <view class="outline-action tap-target" hover-class="tap-press" data-target="points" bindtap="navigate">积分明细 ›</view>
          <view class="outline-action tap-target" hover-class="tap-press" data-target="growth" bindtap="navigate">会员成长 ›</view>
        </view>
        <text class="section-title compact-title">本月专属礼遇</text>
        <view class="mini-benefit-row">
          <view class="mini-benefit tap-target {{coffeeBenefitClaimed ? 'benefit-claimed' : ''}}" hover-class="tap-press" bindtap="claimCoffeeBenefit"><text class="mini-benefit-icon">{{coffeeBenefitClaimed ? '✓' : '咖'}}</text><view><text>咖啡礼遇</text><text class="mini-caption">{{coffeeBenefitClaimed ? '已领取 · 查看卡包' : '指定品牌买一赠一'}}</text></view></view>
          <view class="mini-benefit tap-target" hover-class="tap-press" data-target="points" bindtap="navigate"><text class="mini-benefit-icon">倍</text><view><text>双倍积分日</text><text class="mini-caption">每周五积分双倍</text></view></view>
        </view>
        <view class="member-exclusive wide-benefit soft-card tap-target" hover-class="tap-press" data-target="coupons" bindtap="navigate">
          <view><text class="eyebrow dark-eyebrow">{{homeConfig.memberName}}专享</text><text class="benefit-title">会员专属双倍积分日</text><text class="benefit-sub">每周五到店消费享双倍积分</text></view>
          <view class="benefit-orb">2×</view>
        </view>
      </view>
    </block>

    <!-- 4 会员成长 -->
    <block wx:if="{{currentView === 'growth'}}">
      <view class="content">
        <view class="growth-hero member-theme-{{homeConfig.memberTheme}} elevated-card"><view><text class="member-name"><text class="member-name-key">{{homeConfig.memberName}}</text><text class="member-name-suffix">会员</text></text><text class="growth-value">成长值 8,600</text></view><view class="member-mark large"><text>{{homeConfig.memberMark}}</text></view></view>
        <view class="level-card soft-card">
          <view class="level-line"></view>
          <view class="level-row">
            <view wx:for="{{homeConfig.memberRoadmap}}" wx:key="name" class="level-node {{item.active ? 'active' : ''}}"><view class="node"></view><text>{{item.name}}</text><text>{{item.value}}</text></view>
          </view>
          <text class="level-tip">距{{homeConfig.memberNextLevel}}还差 <text class="gold-number">6,400</text> 成长值</text>
        </view>
        <text class="section-title compact-title">升级礼遇</text>
        <view class="upgrade-banner tap-target" hover-class="tap-press" data-target="activity" bindtap="navigate"><view><text>探索更多艺术体验</text><text class="mini-caption light">升级解锁更高等级礼遇</text></view><text class="white-link">查看权益 ›</text></view>
        <text class="section-title compact-title">本等级权益</text>
        <view class="benefit-grid soft-card">
          <view class="benefit-cell tap-target" hover-class="tap-press" data-detail="birthday" bindtap="openInfoDetail"><view class="circle-icon small">倍</view><text>生日双倍积分</text></view>
          <view class="benefit-cell tap-target" hover-class="tap-press" data-target="parking" bindtap="navigate"><view class="circle-icon small">停</view><text>停车减免2小时</text></view>
          <view class="benefit-cell tap-target" hover-class="tap-press" data-target="activity" bindtap="navigate"><view class="circle-icon small">先</view><text>活动优先报名</text></view>
        </view>
      </view>
    </block>

    <!-- 5 积分中心 -->
    <block wx:if="{{currentView === 'points'}}">
      <view class="content">
        <view class="points-hero elevated-card">
          <view class="points-wallet-top">
            <view class="points-wallet-identity"><view class="points-wallet-mark">积</view><view><text class="points-wallet-title">我的积分账户</text><text class="points-wallet-en">MEMBER POINTS</text></view></view>
            <text class="points-wallet-status">账户正常</text>
          </view>
          <view class="points-balance"><text class="points-balance-label">可用积分</text><view class="points-balance-line"><text class="points-big">{{points}}</text><text class="points-unit">分</text></view></view>
          <view class="points-sub-row">
            <view class="points-metric"><text class="points-metric-label">即将过期</text><view><text class="points-metric-value">800</text><text class="points-metric-unit">分</text></view><text class="points-metric-hint">2026.12.31 前使用</text></view>
            <view class="points-stat-divider"></view>
            <view class="points-metric"><text class="points-metric-label">约可抵扣</text><view><text class="points-metric-value">¥{{pointCash}}</text><text class="points-metric-unit">元</text></view><text class="points-metric-hint">100积分约抵 ¥1</text></view>
          </view>
        </view>
        <view class="dual-actions"><view class="large-action tap-target" hover-class="tap-press" data-target="mall" bindtap="navigate"><text class="action-icon">礼</text>积分兑换</view><view class="large-action tap-target" hover-class="tap-press" data-target="parking" bindtap="navigate"><text class="action-icon">抵</text>积分抵现</view></view>
        <view class="receipt-entry soft-card tap-target" hover-class="tap-press" data-target="receipt" bindtap="navigate"><view class="receipt-entry-icon">扫</view><view><text class="result-title">扫码小票赚积分</text><text class="mini-caption">拍摄或从相册上传消费小票</text></view><text class="gold-arrow">›</text></view>
        <view class="tab-row"><view class="tab {{pointsTab === '明细' ? 'active' : ''}} tap-target" hover-class="tap-press" data-tab="明细" bindtap="setPointsTab">积分明细</view><view class="tab {{pointsTab === '规则' ? 'active' : ''}} tap-target" hover-class="tap-press" data-tab="规则" bindtap="setPointsTab">积分规则</view></view>
        <view wx:if="{{pointsTab === '明细'}}" class="transaction-list soft-card">
          <view wx:for="{{transactions}}" wx:key="title" class="transaction tap-target" hover-class="tap-press" data-detail="transaction" data-index="{{index}}" bindtap="openInfoDetail"><view class="transaction-icon">{{item.icon}}</view><view class="transaction-main"><text>{{item.title}}</text><text class="mini-caption">{{item.date}}</text></view><text class="transaction-value {{item.positive ? 'positive' : ''}}">{{item.value}}</text></view>
        </view>
        <view wx:else class="points-rules-card soft-card"><view><text>消费积分</text><text>每消费1元积1分</text></view><view><text>积分抵扣</text><text>100积分约抵1元</text></view><view><text>积分有效期</text><text>到账次年12月31日</text></view><button class="secondary-button compact" data-detail="pointsRules" bindtap="openInfoDetail">查看完整积分规则</button></view>
      </view>
    </block>

    <!-- 6 卡券权益 -->
    <block wx:if="{{currentView === 'coupons'}}">
      <view class="content">
        <view class="coupon-wallet-head"><view><text class="display-title">卡券与权益</text><text class="display-sub">领取后进入卡包，使用时出示券码</text></view><view class="wallet-mark">券</view></view>
        <view class="summary-chips"><view><text>可领取</text><text class="chip-number">{{availableCouponCount}}</text></view><view><text>我的卡券</text><text class="chip-number">{{ownedCouponCount}}</text></view><view><text>即将过期</text><text class="chip-number">1</text></view></view>
        <view class="tab-row three-tabs"><view wx:for="{{['可领取','我的卡券','会员权益']}}" wx:key="*this" class="tab {{couponTab === item ? 'active' : ''}} tap-target" hover-class="tap-press" data-tab="{{item}}" bindtap="setCouponTab">{{item}}</view></view>
        <block wx:if="{{couponTab === '可领取'}}">
          <view class="coupon-section-tip"><text>领取中心</text><text>以下卡券尚未进入你的卡包</text></view>
          <view wx:for="{{availableCoupons}}" wx:key="id" class="coupon-card available-card tap-target" hover-class="tap-press" data-source="available" data-index="{{index}}" bindtap="openCoupon"><image class="coupon-art" src="{{item.image}}" mode="aspectFill" /><view class="coupon-copy"><text class="coupon-title">{{item.title}}</text><text class="coupon-note">{{item.note}}</text><view><text class="coupon-method">{{item.method}}</text><text class="stock-label">库存{{item.stock}}</text></view></view><view class="coupon-button">{{item.cta}}</view></view>
          <view wx:if="{{availableCouponCount === 0}}" class="empty-state"><view class="empty-orb">✓</view><text class="empty-title">本期卡券已全部领取</text><text>新礼遇上架后会展示在这里</text></view>
        </block>
        <block wx:elif="{{couponTab === '我的卡券'}}">
          <view class="wallet-filter-row"><text class="tap-target {{couponWalletFilter === '可使用' ? 'active' : ''}}" data-filter="可使用" bindtap="setCouponWalletFilter">可使用 {{ownedCouponCount}}</text><text class="tap-target {{couponWalletFilter === '已使用' ? 'active' : ''}}" hover-class="tap-press" data-filter="已使用" bindtap="setCouponWalletFilter">已使用 {{usedCoupons.length}}</text><text class="tap-target {{couponWalletFilter === '已过期' ? 'active' : ''}}" hover-class="tap-press" data-filter="已过期" bindtap="setCouponWalletFilter">已过期 {{expiredCoupons.length}}</text></view>
          <block wx:if="{{couponWalletFilter === '可使用'}}"><view wx:for="{{ownedCoupons}}" wx:key="id" class="coupon-card owned-card tap-target" hover-class="tap-press" data-source="owned" data-index="{{index}}" bindtap="openCoupon"><image class="coupon-art" src="{{item.image}}" mode="aspectFill" /><view class="coupon-copy"><text class="coupon-title">{{item.title}}</text><text class="coupon-note">{{item.note}}</text><text class="status {{item.statusLabel === '可使用' ? '' : 'urgent'}}">{{item.statusLabel}}</text></view><view class="coupon-button use-button">立即使用</view></view></block>
          <block wx:elif="{{couponWalletFilter === '已使用'}}"><view wx:for="{{usedCoupons}}" wx:key="id" class="coupon-card archived-card"><image class="coupon-art" src="{{item.image}}" mode="aspectFill" /><view class="coupon-copy"><text class="coupon-title">{{item.title}}</text><text class="coupon-note">{{item.note}}</text><text class="status">已使用</text></view><view class="archive-state">已核销</view></view></block>
          <block wx:else><view wx:for="{{expiredCoupons}}" wx:key="id" class="coupon-card archived-card"><image class="coupon-art" src="{{item.image}}" mode="aspectFill" /><view class="coupon-copy"><text class="coupon-title">{{item.title}}</text><text class="coupon-note">{{item.note}}</text><text class="status urgent">已过期</text></view><view class="archive-state">不可用</view></view></block>
        </block>
        <block wx:else><view class="empty-state"><view class="empty-orb">权</view><text class="empty-title">8项会员权益待体验</text><text>停车减免、双倍积分、活动优先报名等</text><button class="primary-button compact" hover-class="button-press" data-target="growth" bindtap="navigate">查看会员成长</button></view></block>
      </view>
    </block>

    <!-- 7 AI小票积分 -->
    <block wx:if="{{currentView === 'receipt'}}">
      <view class="content receipt-page">
        <text class="display-title center">拍照上传消费小票</text><text class="display-sub center">上传有效消费小票，获取消费积分</text>
        <view class="camera-frame {{scanning ? 'scanning' : ''}}">
          <view class="corner c1"></view><view class="corner c2"></view><view class="corner c3"></view><view class="corner c4"></view>
          <view class="receipt-paper"><text class="receipt-logo">消费凭证</text><view class="receipt-line long"></view><view class="receipt-line"></view><view class="receipt-line"></view><text class="receipt-total">合计 ¥658.00</text><view class="receipt-line long"></view></view>
          <view class="scan-line"></view>
        </view>
        <view class="guide-chips"><text>✓ 商场名称清晰</text><text>✓ 消费金额完整</text><text>✓ 消费时间可见</text></view>
        <view class="tip-card"><text class="tip-icon">灯</text><view><text>请将小票平铺拍摄，避免反光与遮挡</text><text class="mini-caption">仅支持在有效期内消费的小票</text></view></view>
        <button class="primary-button" hover-class="button-press" bindtap="startScan">{{scanning ? '识别中…' : '拍摄小票'}}</button>
        <button class="secondary-button" hover-class="button-press" bindtap="startScan">从相册选择</button>
        <view class="muted-link tap-target" hover-class="tap-press" data-target="points" bindtap="navigate">查看积分记录 ›</view>
      </view>
    </block>

    <!-- 8 小票结果 -->
    <block wx:if="{{currentView === 'receiptResult'}}">
      <view class="content result-page">
        <view class="success-orb">✓</view><text class="display-title center">小票识别成功</text><text class="score-pill">预计获得 +120 积分</text>
        <view class="result-card soft-card"><view><text>商场名称</text><text>海境艺术中心</text></view><view><text>消费门店</text><text>艺术书廊</text></view><view><text>消费金额</text><text>¥658.00</text></view><view><text>消费时间</text><text>2026-07-18 14:32</text></view></view>
        <view class="timeline-card soft-card"><view class="timeline-line"></view><view class="timeline-node done"><view>✓</view><text>已提交</text></view><view class="timeline-node current"><view>•••</view><text>系统审核中</text></view><view class="timeline-node"><view></view><text>积分到账</text></view></view>
        <text class="microcopy center">预计24小时内完成审核</text>
        <button class="primary-button" hover-class="button-press" bindtap="confirmReceipt">确认提交</button>
        <button class="secondary-button" hover-class="button-press" data-target="receipt" bindtap="navigate">重新拍摄</button>
        <view class="muted-link tap-target" hover-class="tap-press" data-target="points" bindtap="navigate">积分记录 ›</view>
      </view>
    </block>

    <!-- 9 全局搜索 -->
    <block wx:if="{{currentView === 'search'}}">
      <view class="content search-page">
        <view class="search-box"><text>⌕</text><input value="{{searchValue}}" bindinput="onSearchInput" placeholder="搜索品牌、活动或服务"/><text class="clear tap-target" hover-class="tap-press" data-value="" bindtap="setSearch">×</text></view>
        <text class="section-title compact-title">热门搜索</text>
        <view class="hot-chips"><text wx:for="{{['停车缴费','亲子活动','餐饮优惠','会员礼遇']}}" wx:key="*this" class="hot-chip tap-target" hover-class="tap-press" data-value="{{item}}" bindtap="setSearch">{{item}}</text></view>
        <view class="tab-row four-tabs"><view wx:for="{{['全部','店铺','活动','服务']}}" wx:key="*this" class="tab tap-target {{searchFilter === item ? 'active' : ''}}" data-filter="{{item}}" bindtap="setSearchFilter">{{item}}</view></view>
        <view wx:if="{{searchFilter === '全部' || searchFilter === '活动'}}" class="search-result tap-target" hover-class="tap-press" data-target="activity" bindtap="navigate"><image class="result-thumb" src="/assets/images/pop-home/art-festival.jpg" mode="aspectFill" /><view class="result-copy"><text class="result-type">活动</text><text class="result-title">海滨当代艺术展</text><text class="mini-caption">艺术空间 · 报名中</text></view><text>›</text></view>
        <view wx:if="{{searchFilter === '全部' || searchFilter === '店铺'}}" class="search-result tap-target" hover-class="tap-press" data-target="store" bindtap="navigate"><image class="result-thumb" src="/assets/images/pop-home/art-bookshop.jpg" mode="aspectFill" /><view class="result-copy"><text class="result-type">店铺</text><text class="result-title">艺术书廊</text><text class="mini-caption">L1-128 · 营业中</text></view><text>›</text></view>
        <view wx:if="{{searchFilter === '全部' || searchFilter === '服务'}}" class="search-result tap-target" hover-class="tap-press" data-target="guide" bindtap="navigate"><image class="result-thumb" src="/assets/images/pop-home/mall-guide.jpg" mode="aspectFill" /><view class="result-copy"><text class="result-type">服务</text><text class="result-title">艺术展馆导览</text><text class="mini-caption">全馆可用 · 每日三场</text></view><text>›</text></view>
        <text class="section-title compact-title">搜索历史</text><view class="history-row"><text>艺术展览</text><text>艺术书廊</text><text>停车</text></view>
      </view>
    </block>

    <!-- 10 楼层导览 -->
    <block wx:if="{{currentView === 'guide'}}">
      <view class="content guide-page">
        <view class="mall-select tap-target" hover-class="tap-press" bindtap="openMallSheet">{{mallName}}⌄</view>
        <view class="search-box tap-target" hover-class="tap-press" data-target="search" bindtap="navigate"><text>⌕</text><text class="search-placeholder">搜索品牌、店铺或设施</text></view>
        <view class="map-card">
          <image class="guide-map-image" src="/assets/images/pop-home/floor-guide-colorful.jpg" mode="aspectFill" />
          <view class="guide-map-shade"></view><view class="map-center">艺术中庭</view>
          <view class="store-block b1 tap-target" hover-class="tap-press" data-target="store" bindtap="navigate">艺术书廊</view><view class="store-block b2">精品咖啡</view><view class="store-block b3">设计集合</view><view class="store-block b4">亲子空间</view><view class="store-block b5">生活美学</view><view class="store-block b6">海景餐厅</view>
          <view wx:if="{{facilityFilter === '全部' || facilityFilter === '洗手间'}}" class="facility-pin p1">厕</view><view wx:if="{{facilityFilter === '全部' || facilityFilter === '电梯'}}" class="facility-pin p2">梯</view><view wx:if="{{facilityFilter === '全部' || facilityFilter === '母婴室'}}" class="facility-pin p3">母</view><view wx:if="{{facilityFilter === '无障碍'}}" class="facility-pin p3">无</view>
          <view class="floor-selector"><view wx:for="{{['L3','L2','L1','B1']}}" wx:key="*this" class="floor-item {{floor === item ? 'active' : ''}} tap-target" hover-class="tap-press" data-floor="{{item}}" bindtap="setFloor">{{item}}</view></view>
          <view class="guide-toolbar">
            <view class="guide-tool tap-target {{guideMode === '定位' ? 'active' : ''}}" hover-class="tap-press" data-mode="定位" bindtap="setGuideMode"><text class="guide-tool-icon">⌖</text><text>定位</text></view>
            <view class="guide-tool tap-target {{guideMode === '路线' ? 'active' : ''}}" hover-class="tap-press" data-mode="路线" bindtap="setGuideMode"><text class="guide-tool-icon">↝</text><text>路线</text></view>
            <view class="guide-tool tap-target {{guideMode === '设施' ? 'active' : ''}}" hover-class="tap-press" data-mode="设施" bindtap="setGuideMode"><text class="guide-tool-icon">◇</text><text>设施</text></view>
            <view class="guide-tool tap-target" hover-class="tap-press" data-mode="重置" bindtap="setGuideMode"><text class="guide-tool-icon">↻</text><text>重置</text></view>
          </view>
        </view>
        <view class="facility-row"><view class="facility tap-target {{facilityFilter === '洗手间' ? 'active' : ''}}" hover-class="tap-press" data-facility="洗手间" bindtap="setFacilityFilter">厕<text>洗手间</text></view><view class="facility tap-target {{facilityFilter === '母婴室' ? 'active' : ''}}" hover-class="tap-press" data-facility="母婴室" bindtap="setFacilityFilter">母<text>母婴室</text></view><view class="facility tap-target {{facilityFilter === '电梯' ? 'active' : ''}}" hover-class="tap-press" data-facility="电梯" bindtap="setFacilityFilter">梯<text>电梯</text></view><view class="facility tap-target {{facilityFilter === '无障碍' ? 'active' : ''}}" hover-class="tap-press" data-facility="无障碍" bindtap="setFacilityFilter">无<text>无障碍</text></view></view>
        <view class="location-row"><view><text class="mini-caption">{{guideMode === '路线' ? '路线规划中' : (facilityFilter !== '全部' ? '已筛选 ' + facilityFilter : '当前位置')}}</text><text class="result-title">{{floor}} 艺术中庭</text></view><view class="find-car tap-target" hover-class="tap-press" data-target="parking" bindtap="navigate">寻车</view></view>
      </view>
    </block>

    <!-- 11 店铺详情 -->
    <block wx:if="{{currentView === 'store'}}">
      <view class="store-hero hero-art"><image class="material-image" src="/assets/images/pop-home/art-bookshop.jpg" mode="aspectFill" /></view>
      <view class="content store-content">
        <text class="display-title">艺术书廊</text><view class="tag-row"><text>文化艺术</text><text>会员积分</text><text>L1-128</text></view>
        <view class="info-list"><view><text>营业时间</text><text>10:00–22:00 ›</text></view><view><text>联系电话</text><text>0755-8888 6688 ›</text></view></view>
        <text class="store-desc">汇集艺术出版、设计好物与限定展览</text>
        <view class="offer-panel soft-card"><text class="panel-title">当前优惠</text><view class="offer-ticket"><text>消费满200减50</text><view class="small-gold-button tap-target" hover-class="tap-press" bindtap="claimStoreOffer">{{storeOfferClaimed ? '查看卡包' : '立即领取'}}</view></view></view>
        <view class="member-offer tap-target" hover-class="tap-press" data-target="growth" bindtap="navigate"><text>会员可享 双倍积分</text><text>›</text></view>
        <view class="sticky-dual"><button class="secondary-button" hover-class="button-press" bindtap="callStore">电话咨询</button><button class="primary-button" hover-class="button-press" data-target="guide" bindtap="navigate">导航到店</button></view>
      </view>
    </block>

    <!-- 12 停车缴费 -->
    <block wx:if="{{currentView === 'parking'}}">
      <view class="content parking-page">
        <view class="plate-card soft-card tap-target" hover-class="tap-press" bindtap="chooseParkingPlate"><text class="stat-label">车牌号</text><text class="plate">{{selectedParkingPlate}}</text><text>⌄</text></view>
        <view class="parking-record soft-card"><text class="result-title">{{mallName}} 地下停车场</text><view class="parking-times"><view><text class="mini-caption">入场时间</text><text>12:18</text></view><view><text class="mini-caption">已停</text><text>3小时26分</text></view></view></view>
        <view class="fee-card soft-card"><view><text>停车费</text><text>¥36.00</text></view><view><text>{{homeConfig.memberName}}免费2小时</text><text class="discount">-¥20.00</text></view><view><text>停车券</text><text class="discount">-¥10.00</text></view><view class="payable"><text>{{parkingPaid ? '支付状态' : '应付'}}</text><text>{{parkingPaid ? '已支付' : '¥6.00'}}</text></view></view>
        <view class="payment-row soft-card tap-target" hover-class="tap-press" bindtap="chooseParkingPayment"><view class="wechat-dot">{{parkingPayment === '微信支付' ? '微' : '店'}}</view><text>{{parkingPayment}}</text><text>切换 ›</text></view>
        <button class="primary-button" hover-class="button-press" bindtap="payParking">{{parkingPaid ? '支付完成' : '确认支付 ¥6.00'}}</button>
        <view class="bottom-links"><view class="tap-target" hover-class="tap-press" data-target="parkingRecords" bindtap="navigate">停车记录</view><view class="tap-target" hover-class="tap-press" data-target="invoice" bindtap="navigate">申请开票</view></view>
      </view>
    </block>

    <!-- 内容精选 -->
    <block wx:if="{{currentView === 'contentCenter'}}">
      <view class="content content-center-page">
        <view class="content-center-head"><view><text class="eyebrow">EDITORIAL PICKS</text><text class="display-title">内容精选</text><text class="display-sub">根据 {{mallName}} 与{{homeConfig.memberLabel}}偏好推荐</text></view><view class="content-persona">{{homeConfig.memberMark}}<text>会员推荐</text></view></view>
