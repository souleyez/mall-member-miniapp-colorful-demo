  <!-- 积分兑换确认 -->
  <view wx:if="{{exchangeOpen}}" class="sheet-mask" catchtap="closeExchange">
    <view class="confirm-card" catchtap="stopBubble"><view class="confirm-icon">{{exchangeProduct.icon}}</view><text class="sheet-title">确认兑换</text><text class="confirm-name">{{exchangeProduct.name}}</text><text class="confirm-cost">将扣除 {{exchangeProduct.points}} 积分</text><view class="sheet-actions"><button class="secondary-button" hover-class="button-press" bindtap="closeExchange">再想想</button><button class="primary-button" hover-class="button-press" bindtap="confirmExchange">确认兑换</button></view></view>
  </view>
</view>
