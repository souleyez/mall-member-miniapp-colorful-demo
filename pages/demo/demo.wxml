        <view class="reward-config soft-card"><view class="config-title"><text>选择使用积分</text><text class="gold-number">{{rewardPoints}}积分</text></view><slider min="200" max="2000" step="200" value="{{rewardPoints}}" activeColor="#b48122" backgroundColor="#e6dccb" block-color="#e2bd66" bindchange="changeRewardPoints" /><view class="range-label"><text>200</text><text>可用 {{points}}</text><text>2000</text></view><view class="reward-price"><view><text class="mini-caption">使用积分</text><text>- {{rewardPoints}}</text></view><view><text class="mini-caption">需付现金</text><text class="cash-big">¥{{rewardCash}}</text></view></view></view>
        <text class="section-title compact-title">余款支付方式</text>
        <view class="payment-choice soft-card"><view class="tap-target {{rewardPayment === '微信支付' ? 'selected' : ''}}" hover-class="tap-press" data-payment="微信支付" bindtap="setRewardPayment"><view class="wechat-dot">微</view><view><text>微信支付</text><text class="mini-caption">在线完成余款支付</text></view><text>{{rewardPayment === '微信支付' ? '✓' : '○'}}</text></view><view class="tap-target {{rewardPayment === '到店支付' ? 'selected' : ''}}" hover-class="tap-press" data-payment="到店支付" bindtap="setRewardPayment"><view class="store-pay-dot">店</view><view><text>到店支付余下金额</text><text class="mini-caption">核销领取时现场支付</text></view><text>{{rewardPayment === '到店支付' ? '✓' : '○'}}</text></view></view>
        <view class="pickup-tip">凭兑换码到 L1 会员礼宾台核销领取</view>
        <button class="primary-button" hover-class="button-press" bindtap="confirmRewardExchange">确认兑换 · ¥{{rewardCash}}</button>
      </view>
    </block>

    <!-- 会员资料 -->
    <block wx:if="{{currentView === 'memberProfile'}}">
      <view class="content form-page">
        <view class="form-avatar member-theme-{{homeConfig.memberTheme}}"><image class="member-art-seal-image profile-art-seal-image" src="/assets/icons/pop/member-card.png" mode="aspectFit" /><text>{{homeConfig.memberLabel}}</text></view>
        <view class="profile-invite-entry tap-target" hover-class="tap-press" data-target="inviteActivity" bindtap="navigate"><view class="profile-invite-icon">邀</view><view><text>邀请好友注册赚积分</text><text>每成功邀请1位好友，奖励300积分</text></view><view class="profile-invite-reward">+300<text>积分</text></view><text class="profile-invite-arrow">›</text></view>
        <view class="form-card soft-card"><view class="form-row"><text>生日</text><picker mode="date" value="{{memberBirthday}}" bindchange="changeBirthday"><view class="form-value">{{memberBirthday}} ›</view></picker></view><view class="form-row gender-row"><text>性别</text><view><text wx:for="{{['男','女']}}" wx:key="*this" class="gender-chip {{memberGender === item ? 'active' : ''}} tap-target" hover-class="tap-press" data-gender="{{item}}" bindtap="setGender">{{item}}</text></view></view><view class="form-row"><text>手机号</text><input type="number" maxlength="11" value="{{memberPhone}}" bindinput="updateMemberPhone" /></view></view>
        <text class="form-note">生日信息用于发放会员生日礼遇，保存后每年仅可修改一次。</text>
        <button class="primary-button" hover-class="button-press" bindtap="saveProfile">保存会员资料</button>
      </view>
    </block>

    <!-- 邀请好友活动 -->
    <block wx:if="{{currentView === 'inviteActivity'}}">
      <view class="content invite-page">
        <view class="invite-hero">
          <view class="invite-orbit invite-orbit-a"></view><view class="invite-orbit invite-orbit-b"></view>
          <text class="invite-eyebrow">会员好友同行计划</text><text class="invite-title">邀请好友注册\n一起赚积分</text><text class="invite-subtitle">好友完成会员注册，你得300积分，好友得100积分</text>
          <view class="invite-hero-badge"><text>邀</text><view><text>每邀1位</text><text>+300 积分</text></view></view>
        </view>
        <view class="invite-stats soft-card"><view><text>{{invitedCount}}</text><text>成功邀请</text></view><view class="stat-divider"></view><view><text>{{invitePoints}}</text><text>累计积分</text></view><view class="stat-divider"></view><view><text>10</text><text>本月上限</text></view></view>
        <view class="invite-code-card"><view><text>我的专属邀请码</text><text class="invite-code">{{inviteCode}}</text></view><view class="invite-copy tap-target" hover-class="tap-press" bindtap="copyInviteCode">复制</view></view>
        <text class="section-title compact-title">参与方式</text>
        <view class="invite-steps soft-card"><view><text>1</text><view><text>分享邀请</text><text>复制邀请码或生成邀请卡</text></view></view><view><text>2</text><view><text>好友完成注册</text><text>好友使用手机号完成会员注册</text></view></view><view><text>3</text><view><text>积分自动到账</text><text>审核通过后24小时内发放</text></view></view></view>
        <text class="section-title compact-title">邀请记录</text>
        <view class="invite-records soft-card"><view wx:for="{{inviteRecords}}" wx:key="time"><view class="invite-record-avatar">{{item.initial}}</view><view><text>{{item.name}}</text><text>{{item.time}} · {{item.status}}</text></view><text class="invite-record-points">{{item.points}}</text></view></view>
        <view class="invite-rules"><text>活动规则</text><text>每位新会员仅可绑定一个邀请人；同一设备或手机号重复注册不计入奖励；积分以系统审核结果为准。</text></view>
        <button class="primary-button invite-share-button" hover-class="button-press" open-type="share">立即邀请好友</button>
      </view>
    </block>

    <!-- 车辆管理 -->
    <block wx:if="{{currentView === 'vehicles'}}">
      <view class="content vehicle-page">
        <view class="vehicle-summary"><text class="display-title">我的车辆</text><text class="points-pill">已录入 {{vehicles.length}} / 3</text></view>
        <view wx:for="{{vehicles}}" wx:key="plate" class="vehicle-card soft-card"><view class="vehicle-plate"><text>{{item.plate}}</text><text wx:if="{{item.type === '新能源'}}" class="energy-tag">新能源</text></view><text class="mini-caption">{{item.primary ? '默认车辆 · 停车服务优先使用' : item.type + ' · 已绑定'}}</text><view class="vehicle-actions"><view class="tap-target" hover-class="tap-press" data-index="{{index}}" bindtap="editVehicle">编辑</view><view class="tap-target" hover-class="tap-press" data-index="{{index}}" bindtap="setPrimaryVehicle">{{item.primary ? '默认车辆 ✓' : '设为默认'}}</view></view></view>
        <button class="secondary-button vehicle-add-button" hover-class="button-press" bindtap="addVehicle">＋录入新车牌</button>
      </view>
    </block>

    <!-- 商户管理 -->
    <block wx:if="{{currentView === 'merchantManage'}}">
      <view class="content merchant-page">
        <block wx:if="{{merchantPanel === 'home'}}">
          <view class="merchant-workbench">
            <view class="merchant-store-line"><view class="merchant-store-mark">店</view><view><text>商户工作台</text><text>{{mallName}} · 艺术书廊</text></view><text class="merchant-role">运营账号</text></view>
            <view class="merchant-progress"><view><text>资料完整度</text><text>{{merchantProfileCompletion}}%</text></view><view class="merchant-progress-track"><view style="width: {{merchantProfileCompletion}}%;"></view></view><text>完善店铺资料有助于获得更多内容推荐</text></view>
          </view>
          <text class="merchant-section-label">商户应用</text>
          <view class="merchant-app-grid">
            <view class="merchant-app-card tap-target" hover-class="tap-press" data-panel="profile" bindtap="openMerchantPanel"><view class="merchant-app-icon">资</view><text>店铺资料</text><text>品牌介绍与媒体</text></view>
            <view class="merchant-app-card tap-target" hover-class="tap-press" data-panel="news" bindtap="openMerchantPanel"><view class="merchant-app-icon">新</view><text>新品快讯</text><text>发布门店动态</text></view>
            <view class="merchant-app-card tap-target" hover-class="tap-press" data-panel="marketing" bindtap="openMerchantPanel"><view class="merchant-app-icon">营</view><text>营销申请</text><text>权益与活动推广</text></view>
            <view class="merchant-app-card tap-target" hover-class="tap-press" data-panel="approval" bindtap="openMerchantPanel"><view class="merchant-app-icon">审</view><text>审批进度</text><text>{{merchantPendingCount}} 项待跟进</text></view>
          </view>
          <text class="merchant-section-label">今日概览</text>
          <view class="merchant-stats soft-card"><view><text>{{merchantProfileCompletion}}%</text><text>资料完整度</text></view><view><text>{{merchantPendingCount}}</text><text>待处理申请</text></view><view><text>1,286</text><text>近7日曝光</text></view></view>
          <view class="merchant-reminder tap-target" hover-class="tap-press" data-panel="approval" bindtap="openMerchantPanel"><view class="merchant-reminder-icon">!</view><view><text>待办提醒</text><text>新品快讯正在审核，点击查看最新进度</text></view><text>›</text></view>
          <view class="merchant-latest soft-card"><view class="merchant-latest-title"><text>最近提交</text><text class="tap-target" hover-class="tap-press" data-panel="approval" bindtap="openMerchantPanel">查看全部 ›</text></view><view wx:for="{{merchantApprovals}}" wx:key="title" wx:if="{{index < 2}}" class="merchant-latest-row"><view class="merchant-status-dot status-{{item.tone}}"></view><view><text>{{item.title}}</text><text>{{item.type}} · {{item.time}}</text></view><text class="merchant-status status-{{item.tone}}">{{item.status}}</text></view></view>
        </block>

        <block wx:if="{{merchantPanel === 'profile'}}">
          <view class="merchant-subhead"><text class="display-title">店铺资料维护</text><text class="display-sub">完善品牌资料，提升门店展示效果</text></view>
          <view class="merchant-form soft-card">
            <text class="merchant-form-label">品牌名称</text><input value="{{merchantBrandName}}" data-field="merchantBrandName" bindinput="updateMerchantField" />
            <text class="merchant-form-label">品牌描述</text><textarea value="{{merchantDescription}}" data-field="merchantDescription" bindinput="updateMerchantField"></textarea>
            <view class="merchant-field-row"><view><text class="merchant-form-label">营业时间</text><input value="{{merchantHours}}" data-field="merchantHours" bindinput="updateMerchantField" /></view><view><text class="merchant-form-label">联系电话</text><input value="{{merchantPhone}}" data-field="merchantPhone" bindinput="updateMerchantField" /></view></view>
            <text class="merchant-form-label">门店地址</text><input value="{{merchantAddress}}" data-field="merchantAddress" bindinput="updateMerchantField" />
          </view>
          <text class="merchant-section-label">店铺图片 / 视频</text>
          <view class="merchant-media-row"><image src="/assets/images/pop-home/art-bookshop.jpg" mode="aspectFill" /><image src="/assets/images/pop-home/mall-guide.jpg" mode="aspectFill" /><view class="merchant-media-add tap-target" hover-class="tap-press" data-media="图片" bindtap="addMerchantMedia"><text>＋</text><text>图片 {{merchantImageCount}}</text></view><view class="merchant-media-add video tap-target" hover-class="tap-press" data-media="视频" bindtap="addMerchantMedia"><text>▶</text><text>视频 {{merchantVideoCount}}</text></view></view>
          <button class="primary-button merchant-submit" hover-class="button-press" bindtap="saveMerchantProfile">保存并提交审核</button>
        </block>

        <block wx:if="{{merchantPanel === 'news'}}">
          <view class="merchant-subhead"><text class="display-title">发布新品快讯</text><text class="display-sub">让会员第一时间看到门店新鲜内容</text></view>
          <view class="merchant-form soft-card"><text class="merchant-form-label">快讯标题</text><input value="{{merchantNewsTitle}}" data-field="merchantNewsTitle" bindinput="updateMerchantField" /><text class="merchant-form-label">正文内容</text><textarea value="{{merchantNewsContent}}" data-field="merchantNewsContent" bindinput="updateMerchantField"></textarea></view>
          <text class="merchant-section-label">选择封面</text>
          <view class="merchant-cover-row"><image wx:for="{{['/assets/images/pop-home/family-service.jpg','/assets/images/pop-home/art-bookshop.jpg','/assets/images/pop-home/coffee-lifestyle.jpg']}}" wx:key="*this" class="{{merchantCover === item ? 'active' : ''}} tap-target" hover-class="tap-press" src="{{item}}" mode="aspectFill" data-cover="{{item}}" bindtap="chooseMerchantCover" /></view>
          <text class="merchant-section-label">发布范围</text><view class="merchant-choice-row"><view class="merchant-choice {{merchantNewsAudience === '全部会员' ? 'active' : ''}} tap-target" hover-class="tap-press" data-audience="全部会员" bindtap="setMerchantAudience">全部会员</view><view class="merchant-choice {{merchantNewsAudience === homeConfig.memberLabel ? 'active' : ''}} tap-target" hover-class="tap-press" data-audience="{{homeConfig.memberLabel}}" bindtap="setMerchantAudience">{{homeConfig.memberLabel}}</view><view class="merchant-choice {{merchantNewsAudience === '兴趣客群' ? 'active' : ''}} tap-target" hover-class="tap-press" data-audience="兴趣客群" bindtap="setMerchantAudience">兴趣客群</view></view>
          <button class="primary-button merchant-submit" hover-class="button-press" bindtap="submitMerchantNews">提交内容审核</button>
        </block>

        <block wx:if="{{merchantPanel === 'marketing'}}">
          <view class="merchant-subhead"><text class="display-title">营销申请</text><text class="display-sub">提交权益、活动及推荐资源申请</text></view>
          <view class="merchant-type-grid"><view wx:for="{{merchantMarketingTypes}}" wx:key="*this" class="merchant-type-card {{merchantMarketingType === item ? 'active' : ''}} tap-target" hover-class="tap-press" data-type="{{item}}" bindtap="selectMarketingType"><view>{{index === 0 ? '券' : (index === 1 ? '活' : '推')}}</view><text>{{item}}</text><text>{{index === 0 ? '发放会员礼遇' : (index === 1 ? '发起到店活动' : '申请首页曝光')}}</text></view></view>
          <view class="merchant-form soft-card"><text class="merchant-form-label">申请主题</text><input value="{{merchantMarketingTitle}}" data-field="merchantMarketingTitle" bindinput="updateMerchantField" /><text class="merchant-form-label">申请说明</text><textarea value="{{merchantMarketingNote}}" data-field="merchantMarketingNote" bindinput="updateMerchantField"></textarea><view class="merchant-apply-summary"><text>申请类型</text><text>{{merchantMarketingType}}</text></view><view class="merchant-apply-summary"><text>预计审核</text><text>1—2个工作日</text></view></view>
          <button class="primary-button merchant-submit" hover-class="button-press" bindtap="submitMarketingApply">提交营销申请</button>
        </block>

        <block wx:if="{{merchantPanel === 'approval'}}">
          <view class="merchant-subhead"><text class="display-title">审批进度</text><text class="display-sub">查看内容与营销申请的处理状态</text></view>
          <view class="merchant-filter-row"><view wx:for="{{merchantApprovalFilters}}" wx:key="*this" class="merchant-filter {{merchantApprovalFilter === item ? 'active' : ''}} tap-target" hover-class="tap-press" data-filter="{{item}}" bindtap="setMerchantApprovalFilter">{{item}}</view></view>
          <view class="merchant-approval-list"><view wx:for="{{merchantApprovals}}" wx:key="title" wx:if="{{merchantApprovalFilter === '全部' || merchantApprovalFilter === item.status}}" class="merchant-approval-card soft-card"><view class="merchant-approval-top"><text>{{item.type}}</text><text class="merchant-status status-{{item.tone}}">{{item.status}}</text></view><text class="merchant-approval-title">{{item.title}}</text><text class="merchant-approval-time">{{item.time}}</text><view class="merchant-approval-foot"><text>{{item.note}}</text><view class="tap-target" hover-class="tap-press" data-detail="merchantApproval" data-index="{{index}}" bindtap="openInfoDetail">查看详情 ›</view></view></view></view>
        </block>
      </view>
    </block>

    <!-- 设置 -->
    <block wx:if="{{currentView === 'settings'}}">
      <view class="content settings-page"><view class="settings-list soft-card"><view class="tap-target" hover-class="tap-press" data-target="messages" bindtap="navigate"><text>消息通知</text><text>消息中心 ›</text></view><view class="tap-target" hover-class="tap-press" data-detail="privacy" bindtap="openInfoDetail"><text>隐私设置</text><text>›</text></view><view class="tap-target" hover-class="tap-press" bindtap="clearDemoCache"><text>清理缓存</text><text>{{cacheSize}} ›</text></view><view class="tap-target" hover-class="tap-press" data-detail="about" bindtap="openInfoDetail"><text>关于小程序</text><text>演示版 2.1 ›</text></view></view><button class="logout-button" hover-class="button-press" bindtap="logoutDemo">退出登录</button></view>
    </block>

    <!-- 页面自定义 -->
    <block wx:if="{{currentView === 'pageCustomize'}}">
      <view class="content customizer-page">
        <view class="customizer-head">
          <view class="customizer-title-copy"><text class="display-title">首页装修</text><text class="display-sub">选择组件，即时生成客户演示页面</text></view>
          <view class="customizer-count">{{selectedComponents.length}} 个组件</view>
        </view>
        <view class="customizer-preview soft-card">
          <image class="customizer-preview-image" src="/assets/images/pop-home/art-festival.jpg" mode="aspectFill" />
          <view class="customizer-preview-shade"></view>
          <view class="customizer-preview-copy"><text class="customizer-preview-title">当前首页预览</text><text class="customizer-preview-sub">艺术空间 · 会员礼遇</text></view>
          <view class="customizer-preview-cards"><view class="customizer-preview-card"></view><view class="customizer-preview-card"></view><view class="customizer-preview-card"></view></view>
        </view>
        <view class="customizer-toolbar">
          <view class="customizer-preview-button tap-target" hover-class="tap-press" bindtap="previewCustomPage">预览页面</view>
          <view class="customizer-save-button tap-target" hover-class="tap-press" bindtap="saveCustomPage">保存配置</view>
        </view>
        <view class="selected-components soft-card">
          <view class="customizer-section-title"><text>已启用组件</text><text>{{selectedComponents.length}} 项</text></view>
          <view class="selected-component-list"><text wx:for="{{selectedComponents}}" wx:key="*this" class="selected-component-chip">{{item}}</text></view>
        </view>
        <view class="content-ops-panel">
          <view class="content-ops-head"><view><text>内容运营预览</text><text>{{mallName}} · {{homeConfig.memberLabel}} · 本周</text></view><view class="content-ops-live"><text></text>实时数据</view></view>
          <view class="content-ops-types"><text>Banner</text><text>专题页</text><text>品牌故事</text><text>商场资讯</text><text>活动攻略</text><text>服务推荐</text></view>
          <view class="content-ops-metrics"><view wx:for="{{contentOpsMetrics}}" wx:key="label"><text>{{item.label}}</text><text>{{item.value}}</text><text>{{item.trend}}</text></view></view>
          <view class="content-schedule-title"><text>发布计划</text><text class="tap-target" hover-class="tap-press" data-detail="contentStats" bindtap="openInfoDetail">查看明细 ›</text></view>
          <view class="content-schedule-list"><view wx:for="{{contentSchedule}}" wx:key="title"><view class="content-schedule-icon">{{index === 0 ? '专' : '攻'}}</view><view><text>{{item.title}}</text><text>{{item.audience}} · {{item.time}}</text></view><text class="content-schedule-status schedule-{{item.tone}}">{{item.status}}</text></view></view>
        </view>
        <view wx:for="{{pageComponentGroups}}" wx:key="name" wx:for-item="group" wx:for-index="groupIndex" class="component-group">
          <view class="component-group-title"><text class="component-group-name">{{group.name}}</text><text class="component-group-chevron">⌃</text></view>
          <view class="component-grid">
            <view wx:for="{{group.items}}" wx:key="name" wx:for-item="component" wx:for-index="componentIndex" class="component-cell {{component.selected ? 'selected' : ''}} tap-target" hover-class="tap-press" data-group-index="{{groupIndex}}" data-component-index="{{componentIndex}}" bindtap="togglePageComponent">
              <view class="component-icon">{{component.icon}}</view>
              <text class="component-name">{{component.name}}</text>
              <text wx:if="{{component.selected}}" class="component-check">✓</text>
            </view>
          </view>
        </view>
        <button class="primary-button customizer-bottom-save" hover-class="button-press" bindtap="saveCustomPage">保存页面配置</button>
      </view>
    </block>

    <!-- 购物车 -->
    <block wx:if="{{currentView === 'cart'}}">
      <view class="content cart-page"><view wx:for="{{cartItems}}" wx:key="name" class="cart-item soft-card"><image src="{{item.image}}" mode="aspectFill" /><view class="cart-copy"><text class="result-title">{{item.name}}</text><text class="product-points">{{item.points}}积分{{item.cash ? ' + ¥' + item.cash : ''}}</text><view class="qty-stepper"><view class="tap-target" hover-class="tap-press" data-index="{{index}}" data-delta="-1" bindtap="changeCartQty">−</view><text>{{item.qty}}</text><view class="tap-target" hover-class="tap-press" data-index="{{index}}" data-delta="1" bindtap="changeCartQty">＋</view></view></view></view><view class="cart-summary soft-card"><view><text>商品数量</text><text>{{cartCount}}件</text></view><view><text>所需积分</text><text>{{cartTotalPoints}}积分</text></view><view><text>需付现金</text><text class="cash-big">¥{{cartTotalCash}}</text></view></view><button class="primary-button" hover-class="button-press" data-target="checkout" bindtap="navigate">去结算</button></view>
    </block>

    <!-- 商城结算 -->
    <block wx:if="{{currentView === 'checkout'}}">
      <view class="content checkout-page">
        <text class="section-title compact-title">收货地址</text>
        <view class="address-card soft-card"><input value="{{addressName}}" data-field="addressName" bindinput="updateAddress" placeholder="收货人"/><input type="number" value="{{addressPhone}}" data-field="addressPhone" bindinput="updateAddress" placeholder="手机号"/><textarea value="{{addressDetail}}" data-field="addressDetail" bindinput="updateAddress" placeholder="省市区及详细地址"></textarea></view>
        <text class="section-title compact-title">兑换清单</text>
        <view class="checkout-goods soft-card"><view wx:for="{{cartItems}}" wx:key="name"><image src="{{item.image}}" mode="aspectFill"/><text>{{item.name}} ×{{item.qty}}</text></view></view>
        <text class="section-title compact-title">积分与现金</text>
