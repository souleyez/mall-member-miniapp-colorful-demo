.theme-pop .elevated-card > .display-sub:last-child {
  margin-bottom: 0;
}

.theme-pop .wallet-filter-row,
.theme-pop .tab-row,
.theme-pop .coupon-section-tip {
  margin-top: 20rpx;
}

.theme-pop .merchant-section-label,
.theme-pop .section-title.compact-title {
  margin-bottom: 18rpx;
}

/* 会员卡：让身份文字与卡片、徽章边缘保持稳定的呼吸区。 */
.theme-pop .membership-card {
  padding: 36rpx 42rpx 32rpx;
  box-sizing: border-box;
}

.theme-pop .membership-logo {
  line-height: 1.35;
}

.theme-pop .membership-level {
  gap: 14rpx;
  margin-top: 36rpx;
  line-height: 1.15;
}

.theme-pop .membership-card .member-name-suffix {
  margin-left: 0;
  padding: 7rpx 14rpx 6rpx;
  line-height: 1.25;
  border: 0 !important;
  border-radius: 999rpx;
}

.theme-pop .membership-id {
  margin-top: 14rpx;
  line-height: 1.4;
}

/* 首页头图：扩大文字安全区，标签使用色块而非生硬实线框。 */
.theme-pop .pop-hero-poster {
  padding-left: 56rpx;
  padding-right: 56rpx;
}

.theme-pop .pop-hero-copy {
  box-sizing: border-box;
  padding: 8rpx 4rpx 0;
}

.theme-pop .pop-hero-kicker {
  padding: 10rpx 20rpx 9rpx;
  line-height: 1.35;
  border: 0 !important;
}

.theme-pop .pop-hero-title {
  margin-top: 28rpx;
  line-height: 1.14;
}

.theme-pop .pop-hero-ribbon {
  margin-top: 24rpx;
  padding: 13rpx 28rpx 12rpx;
  line-height: 1.3;
  border: 0 !important;
}

.theme-pop .pop-hero-date {
  margin-top: 18rpx;
  line-height: 1.4;
}

.theme-pop .pop-hero-action {
  min-height: 62rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 0 !important;
}

.theme-pop .pop-hero-poster-sunset {
  padding: 58rpx 50rpx 46rpx;
}

.theme-pop .pop-hero-poster-sunset .pop-hero-title {
  margin-top: 24rpx;
}

.theme-pop .pop-hero-poster-sunset .pop-hero-ribbon {
  margin-top: 20rpx;
}

.theme-pop .pop-hero-poster-sunset .pop-hero-date {
  margin-top: 16rpx;
}

.theme-pop .pop-hero-poster-garden {
  padding: 70rpx 50rpx 46rpx;
}

/* 云庭首页：优惠券先行，八项服务自然下移，形成与其他商场不同的首屏节奏。 */
.theme-pop .home-coupon-showcase {
  margin: 0 0 30rpx;
}

.theme-pop .home-coupon-showcase-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 6rpx 17rpx;
}

.theme-pop .home-coupon-showcase-head > view:first-child {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.theme-pop .home-coupon-showcase-head > view:first-child text:first-child {
  color: var(--pop-ink);
  font-size: 34rpx;
  font-weight: 900;
}

.theme-pop .home-coupon-showcase-head > view:first-child text:last-child {
  color: var(--pop-muted);
  font-size: 20rpx;
  font-weight: 650;
}

.theme-pop .home-coupon-showcase-head > view:last-child {
  padding: 8rpx 13rpx;
  color: #713e64;
  background: var(--pop-pink-soft);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.theme-pop .home-coupon-showcase-scroll {
  width: calc(100% + 24rpx);
}

.theme-pop .home-coupon-showcase-track {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 24rpx 4rpx 0;
}

.theme-pop .home-coupon-mini {
  position: relative;
  width: 300rpx;
  min-height: 190rpx;
  padding: 20rpx 22rpx 18rpx;
  overflow: hidden;
  box-sizing: border-box;
  display: flex;
  flex: none;
  flex-direction: column;
  color: var(--pop-ink);
  background: linear-gradient(145deg, #fff0f8, var(--pop-pink-soft));
  border: 0;
  border-radius: 30rpx 22rpx 34rpx 24rpx;
}

.theme-pop .home-coupon-mini::after {
  content: "券";
  position: absolute;
  right: 12rpx;
  bottom: -18rpx;
  color: rgba(255, 255, 255, .62);
  font-size: 100rpx;
  font-weight: 900;
  line-height: 1;
  transform: rotate(-8deg);
}

.theme-pop .home-coupon-mini:nth-child(2) {
  background: linear-gradient(145deg, #edf8ff, var(--pop-blue-soft));
}

.theme-pop .home-coupon-mini:nth-child(3) {
  background: linear-gradient(145deg, #edfff9, var(--pop-mint-soft));
}

.theme-pop .home-coupon-mini-top,
.theme-pop .home-coupon-mini-bottom {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.theme-pop .home-coupon-mini-top text:first-child {
  padding: 6rpx 11rpx;
  background: rgba(255, 255, 255, .72);
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
}

.theme-pop .home-coupon-mini-top text:last-child {
  color: rgba(32, 35, 33, .5);
  font-size: 15rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.theme-pop .home-coupon-mini-title {
  position: relative;
  z-index: 1;
  margin-top: 15rpx;
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.24;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.theme-pop .home-coupon-mini-note {
  position: relative;
  z-index: 1;
  margin-top: 6rpx;
  overflow: hidden;
  color: #626966;
  font-size: 19rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.theme-pop .home-coupon-mini-bottom {
  margin-top: auto;
  padding-top: 14rpx;
  font-size: 19rpx;
  font-weight: 800;
}

.theme-pop .home-coupon-mini-bottom text:last-child {
  color: #9b2864;
}

.theme-pop .home-coupon-mini:nth-child(2) .home-coupon-mini-bottom text:last-child {
  color: #245f9e;
}

.theme-pop .home-coupon-mini:nth-child(3) .home-coupon-mini-bottom text:last-child {
  color: #247565;
}

/* 首页主广告完整展示：由实际内容撑开高度，避免不同状态栏下裁掉海报底边。 */
.theme-pop .pop-home-hero {
  height: auto;
  min-height: 0;
  padding-bottom: 42rpx;
}

.theme-pop .pop-hero-swiper {
  width: 100%;
  height: 594rpx;
  margin-top: 26rpx;
}

.theme-pop .pop-hero-swiper swiper-item {
  overflow: hidden;
}

.theme-pop .pop-hero-swiper .pop-hero-poster {
  width: 100%;
  height: 594rpx;
  margin-top: 0;
}

.theme-pop .pop-hero-dots {
  bottom: 13rpx;
}
