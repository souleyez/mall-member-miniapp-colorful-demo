/*
 * 彩色手绘版视觉系统
 * 由 GPT-image-2 主风格稿提炼：白底、薄荷绿、亮黄/粉/蓝/紫点缀、黑色手绘轮廓。
 * 仅使用 CSS 与原有业务素材，避免新增大图导致小程序包体膨胀。
 */

.theme-pop {
  --pop-ink: #202321;
  --pop-muted: #747b78;
  --pop-mint: #63c8b0;
  --pop-mint-dark: #299b84;
  --pop-mint-soft: #e9f8f3;
  --pop-yellow: #ffd83d;
  --pop-yellow-soft: #fff6bd;
  --pop-pink: #f05aa6;
  --pop-pink-soft: #ffe5f2;
  --pop-blue: #5da9ff;
  --pop-blue-soft: #e4f1ff;
  --pop-violet: #9b6de3;
  --pop-violet-soft: #eee7ff;
  --pop-coral: #ff765f;
  --pop-paper: #ffffff;
  --pop-bg: #f7faf9;
  /* 重映射旧版组件仍会读取的变量，杜绝内页回落到暗金配色 */
  --surface: #f7faf9;
  --surface-card: #ffffff;
  --surface-soft: #e9f8f3;
  --ink: #202321;
  --muted: #747b78;
  --line: #dce8e4;
  --gold: #f05aa6;
  --gold-light: #ffd83d;
  --gold-soft: #e4f1ff;
  min-height: 100vh;
  color: var(--pop-ink);
  background: var(--pop-bg);
}

.theme-pop .screen {
  min-height: 100vh;
  color: var(--pop-ink);
  background:
    radial-gradient(circle at 92% 16%, rgba(99, 200, 176, .12) 0, rgba(99, 200, 176, .12) 82rpx, transparent 84rpx),
    var(--pop-bg);
}

.theme-pop .nav-bar {
  color: var(--pop-ink);
  background: rgba(255, 255, 255, .97);
  border-bottom: 1rpx solid #e7efec;
  box-shadow: 0 8rpx 24rpx rgba(32, 35, 33, .04);
}

.theme-pop .nav-title,
.theme-pop .display-title,
.theme-pop .section-title,
.theme-pop .result-title {
  color: var(--pop-ink);
  font-weight: 800;
  letter-spacing: -.5rpx;
}

.theme-pop .nav-back {
  color: var(--pop-ink);
  background: transparent;
}

.theme-pop .display-sub,
.theme-pop .mini-caption,
.theme-pop .section-sub,
.theme-pop .search-placeholder {
  color: var(--pop-muted);
}

.theme-pop .eyebrow,
.theme-pop .section-en {
  width: fit-content;
  color: #755616;
  background: var(--pop-yellow-soft);
  border: 2rpx solid #efd35c;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  letter-spacing: 5rpx;
}

.theme-pop .content {
  background: transparent;
}

.theme-pop .soft-card,
.theme-pop .elevated-card,
.theme-pop .service-card,
.theme-pop .search-result,
.theme-pop .coupon-card,
.theme-pop .product-card,
.theme-pop .order-card,
.theme-pop .vehicle-card,
.theme-pop .parking-history-card,
.theme-pop .message-card,
.theme-pop .merchant-app-card,
.theme-pop .borrow-card,
.theme-pop .loan-record,
.theme-pop .loan-item,
.theme-pop .cart-item,
.theme-pop .activity-list-card,
.theme-pop .content-featured,
.theme-pop .custom-live-module {
  color: var(--pop-ink);
  background: var(--pop-paper);
  border: 2rpx solid #e1eae7;
  box-shadow: 0 12rpx 30rpx rgba(34, 63, 55, .08);
}

.theme-pop .primary-button,
.theme-pop .large-action,
.theme-pop .exchange-button,
.theme-pop .coupon-button,
.theme-pop .chat-composer button {
  color: #202321;
  background: var(--pop-yellow);
  border: 3rpx solid var(--pop-ink);
  box-shadow: 5rpx 6rpx 0 rgba(32, 35, 33, .14);
  font-weight: 800;
}

.theme-pop .secondary-button,
.theme-pop .outline-action,
.theme-pop .small-gold-button {
  color: var(--pop-ink);
  background: #fff;
  border: 2rpx solid var(--pop-mint);
  box-shadow: none;
  font-weight: 700;
}

.theme-pop .tap-press,
.theme-pop .button-press {
  opacity: .94;
  filter: brightness(.98) saturate(.96);
  transform: none;
  box-shadow: inherit;
}

.theme-pop .gold-arrow,
.theme-pop .gold-text {
  color: var(--pop-mint-dark);
}

.theme-pop .status,
.theme-pop .current-label,
.theme-pop .result-type {
  color: #207e6a;
  background: var(--pop-mint-soft);
  border: 1rpx solid #a5dfd1;
}

.theme-pop .tab,
.theme-pop .activity-filter,
.theme-pop .merchant-filter,
.theme-pop .hot-chip {
  color: #59615e;
  background: #fff;
  border: 2rpx solid #d8e6e1;
}

.theme-pop .tab.active,
.theme-pop .activity-filter.active,
.theme-pop .merchant-filter.active,
.theme-pop .hot-chip.active {
  color: var(--pop-ink);
  background: var(--pop-yellow-soft);
  border-color: #efd04e;
}

.theme-pop input,
.theme-pop textarea,
.theme-pop .form-input,
.theme-pop .address-input {
  color: var(--pop-ink);
  background: #fff;
  border-color: #cfe3dc;
}

/* 首页：GPT-image-2 主视觉稿的可运行实现 */
.theme-pop .pop-home-hero {
  position: relative;
  overflow: hidden;
  height: 760rpx;
  padding: calc(env(safe-area-inset-top) + 26rpx) 28rpx 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #6fd0b9 0, #62c6ae 134rpx, #fff 135rpx, #fff 100%);
}

.theme-pop .pop-home-hero::after {
  content: '';
  position: absolute;
  right: -50rpx;
  bottom: 32rpx;
  width: 190rpx;
  height: 190rpx;
  border: 26rpx solid rgba(155, 109, 227, .12);
  border-radius: 50%;
}

.theme-pop .mall-pill {
  position: relative;
  z-index: 5;
  width: fit-content;
  max-width: 590rpx;
  min-height: 60rpx;
  padding: 0 24rpx 0 16rpx;
  color: var(--pop-ink);
  background: rgba(255, 255, 255, .9);
  border: 2rpx solid rgba(32, 35, 33, .18);
  border-radius: 999rpx;
  box-shadow: 4rpx 5rpx 0 rgba(32, 35, 33, .09);
}

.theme-pop .pop-location-dot {
  width: 22rpx;
  height: 22rpx;
  margin-right: 12rpx;
  background: var(--pop-pink);
  border: 3rpx solid var(--pop-ink);
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
}

.theme-pop .pop-hero-poster {
  position: relative;
  z-index: 2;
  overflow: hidden;
  height: 594rpx;
  margin-top: 26rpx;
  padding: 70rpx 48rpx 42rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 84% 24%, rgba(93, 169, 255, .23) 0 56rpx, transparent 58rpx),
    linear-gradient(145deg, #fffef7 0, #fff 62%, #fff8d7 100%);
  border: 3rpx solid var(--pop-ink);
  border-radius: 36rpx 50rpx 34rpx 56rpx;
  box-shadow: 10rpx 12rpx 0 rgba(32, 35, 33, .13);
}

.theme-pop .pop-hero-poster::after {
  content: '';
  position: absolute;
  z-index: 1;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(90deg, rgba(255,255,255,.92) 0%, rgba(255,255,255,.74) 43%, rgba(255,255,255,.06) 76%);
}

.theme-pop .pop-paper-edge {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(135deg, transparent 12rpx, rgba(255, 216, 61, .33) 13rpx 28rpx, transparent 29rpx) left bottom / 58rpx 34rpx repeat-x;
  opacity: .75;
}

.theme-pop .pop-doodle {
  position: absolute;
  z-index: 1;
  display: block;
}

.theme-pop .pop-doodle-star {
  top: 44rpx;
  right: 52rpx;
  width: 46rpx;
  height: 46rpx;
  background: var(--pop-yellow);
  border: 3rpx solid var(--pop-ink);
  transform: rotate(17deg);
  clip-path: polygon(50% 0, 61% 35%, 98% 35%, 68% 56%, 79% 95%, 50% 72%, 19% 95%, 31% 56%, 2% 35%, 39% 35%);
}

.theme-pop .pop-doodle-wave {
  left: 34rpx;
  bottom: 48rpx;
  width: 116rpx;
  height: 46rpx;
  border-top: 12rpx solid var(--pop-blue);
  border-radius: 50%;
  transform: rotate(-13deg);
}

.theme-pop .pop-doodle-dot {
  top: 165rpx;
  right: 102rpx;
  width: 24rpx;
  height: 24rpx;
  background: var(--pop-pink);
  border: 3rpx solid var(--pop-ink);
  border-radius: 50%;
  box-shadow: 34rpx 22rpx 0 var(--pop-violet), -18rpx 45rpx 0 var(--pop-yellow);
}

.theme-pop .pop-hero-copy {
  position: relative;
  z-index: 3;
}

.theme-pop .pop-hero-kicker {
  display: inline-block;
  padding: 8rpx 18rpx;
  color: var(--pop-ink);
  background: var(--pop-yellow);
  border: 3rpx solid var(--pop-ink);
  border-radius: 8rpx 15rpx 8rpx 14rpx;
  font-size: 22rpx;
  font-weight: 800;
  transform: rotate(-2deg);
}

.theme-pop .pop-hero-title {
  display: block;
  max-width: 520rpx;
  margin-top: 24rpx;
  color: var(--pop-ink);
  font-size: 62rpx;
  line-height: 1.08;
  font-weight: 900;
  letter-spacing: -3rpx;
}

.theme-pop .pop-hero-ribbon {
  display: inline-block;
  margin-top: 22rpx;
  padding: 10rpx 26rpx;
  color: #fff;
  background: var(--pop-pink);
  border: 3rpx solid var(--pop-ink);
  border-radius: 6rpx 14rpx 7rpx 12rpx;
  font-size: 32rpx;
  font-weight: 900;
  box-shadow: 5rpx 6rpx 0 var(--pop-yellow);
  transform: rotate(-1deg);
}

.theme-pop .pop-hero-date {
  display: block;
  margin-top: 22rpx;
  color: #535956;
  font-size: 24rpx;
  font-weight: 700;
}

.theme-pop .pop-door {
  position: absolute;
  right: 56rpx;
  bottom: 54rpx;
  z-index: 2;
  width: 142rpx;
  height: 190rpx;
  background: var(--pop-yellow);
  border: 5rpx solid var(--pop-ink);
  border-radius: 22rpx 22rpx 8rpx 8rpx;
  box-shadow: inset -18rpx -12rpx 0 #ffb640, 10rpx 12rpx 0 rgba(32, 35, 33, .12);
  transform: rotate(5deg);
}

.theme-pop .pop-door::before {
  content: '';
  position: absolute;
  inset: 24rpx 24rpx 34rpx;
  background: var(--pop-blue);
  border: 4rpx solid var(--pop-ink);
  border-radius: 10rpx;
}

.theme-pop .pop-door::after {
  content: '★';
  position: absolute;
  top: 57rpx;
  left: 50rpx;
  color: var(--pop-yellow);
  font-size: 40rpx;
}

.theme-pop .pop-runner {
  position: absolute;
  right: 180rpx;
  bottom: 82rpx;
  z-index: 4;
  width: 92rpx;
  height: 18rpx;
  background: var(--pop-blue);
  border: 4rpx solid var(--pop-ink);
  border-radius: 999rpx;
  transform: rotate(-21deg);
}

.theme-pop .pop-runner::before,
.theme-pop .pop-runner::after {
  content: '';
  position: absolute;
  width: 80rpx;
  height: 16rpx;
  background: var(--pop-blue);
  border: 4rpx solid var(--pop-ink);
  border-radius: 999rpx;
}

.theme-pop .pop-runner::before { left: 16rpx; top: -42rpx; transform: rotate(55deg); }
.theme-pop .pop-runner::after { left: 20rpx; top: 40rpx; transform: rotate(-48deg); }

.theme-pop .pop-hero-action {
  position: absolute;
  left: 48rpx;
  bottom: 42rpx;
  z-index: 5;
  padding: 15rpx 32rpx;
  color: var(--pop-ink);
  background: #fff;
  border: 3rpx solid var(--pop-ink);
  border-radius: 999rpx;
  font-weight: 800;
  box-shadow: 5rpx 6rpx 0 var(--pop-mint);
}

.theme-pop .pop-hero-dots {
  position: absolute;
  z-index: 6;
  left: 50%;
  bottom: 4rpx;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
}

.theme-pop .pop-hero-dots text {
  width: 10rpx;
  height: 10rpx;
  background: #d8dfdc;
  border-radius: 50%;
}

.theme-pop .pop-hero-dots .active {
  width: 28rpx;
  background: var(--pop-ink);
  border-radius: 999rpx;
}

.theme-pop .home-body {
  margin-top: 0;
  padding-top: 26rpx;
  background: var(--pop-bg);
}

.theme-pop .pop-shortcut-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 28rpx 12rpx;
  padding: 20rpx 4rpx 34rpx;
}

.theme-pop .pop-shortcut {
  display: flex;
  width: auto;
  min-width: 0;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: var(--pop-ink);
  font-size: 23rpx;
  font-weight: 700;
}

.theme-pop .pop-shortcut .shortcut-label {
  margin-top: 0;
  color: #4f5653;
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 0;
  white-space: nowrap;
}

.theme-pop .pop-line-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  padding: 4rpx;
  box-sizing: border-box;
  background: var(--pop-yellow-soft);
  border: 2rpx solid #ead16e;
  border-radius: 22rpx 26rpx 20rpx 24rpx;
  box-shadow: 0 7rpx 16rpx rgba(44, 66, 59, .1);
}

.theme-pop .tone-pink .pop-line-icon { background: var(--pop-pink-soft); border-color: #f2a6cc; }
.theme-pop .tone-blue .pop-line-icon { background: var(--pop-blue-soft); border-color: #a9cef7; }
.theme-pop .tone-violet .pop-line-icon { background: var(--pop-violet-soft); border-color: #c6afe9; }
.theme-pop .tone-mint .pop-line-icon { background: var(--pop-mint-soft); border-color: #9edbcd; }

.theme-pop .pop-line-icon-image {
  width: 72rpx;
  height: 72rpx;
}

.theme-pop .pop-member-strip {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  color: var(--pop-ink);
  background: linear-gradient(105deg, var(--pop-mint-soft), #fff 68%);
  border: 3rpx solid var(--pop-ink);
  border-radius: 28rpx 32rpx 24rpx 34rpx;
  box-shadow: 6rpx 7rpx 0 rgba(32, 35, 33, .1);
}

.theme-pop .pop-member-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 76rpx;
  width: 76rpx;
  height: 76rpx;
  color: var(--pop-ink);
  background: var(--pop-yellow);
  border: 3rpx solid var(--pop-ink);
  border-radius: 50%;
  font-size: 38rpx;
  font-weight: 900;
}

.theme-pop .pop-member-strip > view:nth-child(2) {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.theme-pop .pop-member-strip > view:nth-child(2) text:first-child { font-size: 30rpx; font-weight: 900; }
.theme-pop .pop-member-strip > view:nth-child(2) text:last-child { color: var(--pop-muted); font-size: 22rpx; }
.theme-pop .pop-member-arrow { color: var(--pop-pink); font-size: 48rpx; font-weight: 900; }

.theme-pop .home-coupon-teaser {
  background: linear-gradient(105deg, var(--pop-yellow-soft), #fff 56%, var(--pop-pink-soft));
  border: 3rpx dashed var(--pop-ink);
  box-shadow: 6rpx 7rpx 0 rgba(240, 90, 166, .13);
}

.theme-pop .activity-banner {
  border: 3rpx solid var(--pop-ink);
  border-radius: 28rpx 36rpx 28rpx 42rpx;
  box-shadow: 7rpx 8rpx 0 rgba(93, 169, 255, .2);
}

.theme-pop .inspiration-card,
.theme-pop .waterfall-card {
  border: 2rpx solid #dce9e5;
  box-shadow: 0 10rpx 24rpx rgba(45, 83, 72, .08);
}

.theme-pop .waterfall-card:nth-child(4n+1) .waterfall-tag { background: var(--pop-yellow-soft); color: #684d00; }
.theme-pop .waterfall-card:nth-child(4n+2) .waterfall-tag { background: var(--pop-pink-soft); color: #9b2864; }
.theme-pop .waterfall-card:nth-child(4n+3) .waterfall-tag { background: var(--pop-blue-soft); color: #245f9e; }
.theme-pop .waterfall-card:nth-child(4n) .waterfall-tag { background: var(--pop-violet-soft); color: #5e3b99; }

/* 五栏底部导航 */
.theme-pop .bottom-nav {
  left: 0;
  right: 0;
  bottom: 0;
  width: auto;
  min-height: 118rpx;
  padding: 12rpx 12rpx calc(12rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 255, 255, .98);
  border: 0;
  border-top: 2rpx solid #dce8e4;
  border-radius: 0;
  box-shadow: 0 -10rpx 28rpx rgba(32, 35, 33, .08);
}

.theme-pop .bottom-item {
  width: 20%;
  color: #626966;
  gap: 3rpx;
}

.theme-pop .bottom-item.active {
  color: var(--pop-ink);
  background: transparent;
}

.theme-pop .pop-bottom-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  color: var(--pop-ink);
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
  border-radius: 16rpx;
}

.theme-pop .bottom-item:nth-child(1) .pop-bottom-icon { background: var(--pop-violet-soft); }
.theme-pop .bottom-item:nth-child(2) .pop-bottom-icon { background: var(--pop-mint-soft); }
.theme-pop .bottom-item:nth-child(3) .pop-bottom-icon { background: var(--pop-pink-soft); }
.theme-pop .bottom-item:nth-child(4) .pop-bottom-icon { background: var(--pop-yellow-soft); }
.theme-pop .bottom-item:nth-child(5) .pop-bottom-icon { background: var(--pop-blue-soft); }
.theme-pop .bottom-item.active .pop-bottom-icon { border: 2rpx solid var(--pop-ink); box-shadow: 3rpx 3rpx 0 var(--pop-yellow); }
.theme-pop .bottom-label { font-size: 20rpx; font-weight: 700; }

/* 个人中心 / 会员 / 积分 */
.theme-pop .profile-page,
.theme-pop .membership-page,
.theme-pop .points-page,
.theme-pop .growth-page {
  background: var(--pop-bg);
}

.theme-pop .profile-hero {
  color: var(--pop-ink);
  background: linear-gradient(145deg, var(--pop-mint-soft), #fff 55%, var(--pop-yellow-soft));
  border-bottom: 3rpx solid var(--pop-ink);
}

.theme-pop .pop-profile-hero {
  position: relative;
  overflow: hidden;
  height: 330rpx;
  padding: 72rpx 42rpx 34rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, var(--pop-mint) 0, #9de2d1 56%, var(--pop-yellow-soft) 100%);
  border-bottom: 3rpx solid var(--pop-ink);
}

.theme-pop .pop-profile-copy {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}

.theme-pop .pop-profile-copy text:nth-child(1) {
  padding: 6rpx 16rpx;
  color: var(--pop-ink);
  background: #fff;
  border: 2rpx solid var(--pop-ink);
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.theme-pop .pop-profile-copy text:nth-child(2) {
  color: var(--pop-ink);
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.theme-pop .pop-profile-copy text:nth-child(3) {
  color: #31433e;
  font-size: 24rpx;
  font-weight: 700;
}

.theme-pop .pop-profile-face {
  position: absolute;
  z-index: 3;
  right: 46rpx;
  bottom: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 134rpx;
  height: 134rpx;
  color: var(--pop-ink);
  background: var(--pop-pink-soft);
  border: 4rpx solid var(--pop-ink);
  border-radius: 48% 52% 46% 54%;
  box-shadow: 7rpx 8rpx 0 var(--pop-yellow);
  font-size: 72rpx;
  transform: rotate(5deg);
}

.theme-pop .pop-profile-sun {
  position: absolute;
  top: -70rpx;
  right: -42rpx;
  width: 240rpx;
  height: 240rpx;
  background: var(--pop-yellow);
  border: 4rpx solid var(--pop-ink);
  border-radius: 50%;
  opacity: .92;
}

.theme-pop .pop-profile-wave {
  position: absolute;
  left: -25rpx;
  bottom: -52rpx;
  width: 340rpx;
  height: 116rpx;
  border: 20rpx solid rgba(93, 169, 255, .75);
  border-color: rgba(93, 169, 255, .75) transparent transparent transparent;
  border-radius: 50%;
  transform: rotate(-6deg);
}

.theme-pop .pop-profile-star {
  position: absolute;
  left: 382rpx;
  top: 58rpx;
  color: var(--pop-pink);
  font-size: 48rpx;
  transform: rotate(18deg);
}

.theme-pop .pop-profile-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  color: var(--pop-ink);
  background: var(--pop-yellow);
  border: 4rpx solid var(--pop-ink);
  border-radius: 26rpx 30rpx 23rpx 28rpx;
  box-shadow: 5rpx 6rpx 0 var(--pop-pink);
  font-size: 46rpx;
  font-weight: 900;
}

.theme-pop .profile-content .identity-row {
  column-gap: 26rpx;
}

