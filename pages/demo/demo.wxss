@import "./pop-theme.wxss";

:root {
  --surface: #e4f1ff;
  --surface-card: #eee7ff;
  --surface-soft: #ffe5f2;
  --ink: #202321;
  --muted: #202321;
  --line: #f4b5d5;
  --gold: #a83774;
  --gold-light: #63c8b0;
  --gold-soft: #f4b5d5;
}

.demo-page {
  width: 100%;
  min-height: 100vh;
  overflow-x: hidden;
  background: #e4f1ff;
}

.screen {
  width: 100%;
  min-height: 100vh;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 88% 8%, rgba(93,169,255, 0.2), transparent 32%),
    #e4f1ff;
  opacity: 1;
  transform: translateY(0);
}

.screen-with-bottom {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.screen-enter {
  animation: screenEnter 300ms cubic-bezier(0.22, 0.72, 0.24, 1) both;
}

.screen-leave {
  animation: screenLeave 120ms ease both;
}

@keyframes screenEnter {
  from { opacity: 0; transform: translateY(18rpx) scale(0.995); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes screenLeave {
  from { opacity: 1; transform: translateY(0); }
  to { opacity: 0; transform: translateY(8rpx); }
}

.tap-target,
.primary-button,
.secondary-button {
  transition: opacity 120ms ease, filter 140ms ease, background-color 160ms ease;
}

.tap-press,
.button-press {
  transform: none !important;
  opacity: 0.985;
  filter: brightness(0.985);
}

.nav-safe {
  height: calc(env(safe-area-inset-top) + 18rpx);
}

.nav-bar {
  position: relative;
  z-index: 30;
  height: 88rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(228,241,255, 0.91);
  backdrop-filter: blur(18px);
  border-bottom: 1rpx solid rgba(244,181,213, 0.55);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  font-size: 54rpx;
  line-height: 1;
}

.nav-title {
  position: absolute;
  left: 170rpx;
  right: 170rpx;
  text-align: center;
  font-size: 31rpx;
  font-weight: 650;
}

.content {
  padding: 28rpx 30rpx 50rpx;
}

.soft-card,
.elevated-card {
  background: rgba(238,231,255, 0.94);
  border: 1rpx solid rgba(183,229,218, 0.62);
  border-radius: 28rpx;
  box-shadow: 0 14rpx 30rpx rgba(43,96,148, 0.075), inset 0 2rpx 0 rgba(255, 255, 255, 0.95);
}

.elevated-card {
  box-shadow: 0 22rpx 46rpx rgba(36,111,98, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
}

.primary-button,
.secondary-button {
  width: 100%;
  min-height: 92rpx;
  margin: 20rpx 0 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 650;
  line-height: 1.2;
}

.primary-button {
  color: #fff;
  background: linear-gradient(145deg, #63c8b0, #2b6094 66%, #2b6094);
  box-shadow: 0 13rpx 24rpx rgba(43,96,148, 0.31), inset 0 3rpx 3rpx rgba(255, 255, 255, 0.4), inset 0 -4rpx 8rpx rgba(168,55,116, 0.22);
}

.secondary-button {
  color: #246f62;
  background: linear-gradient(160deg, #eee7ff, #eee7ff);
  border: 1rpx solid rgba(43,96,148, 0.5);
  box-shadow: 0 8rpx 16rpx rgba(111,74,172, 0.08), inset 0 3rpx 3rpx rgba(255, 255, 255, 0.9);
}

.primary-button.compact,
.secondary-button.compact {
  width: auto;
  min-width: 280rpx;
  min-height: 78rpx;
  padding: 0 40rpx;
}

.display-title {
  display: block;
  margin: 10rpx 0 12rpx;
  font-size: 46rpx;
  font-weight: 760;
  letter-spacing: -1rpx;
  line-height: 1.25;
}

.display-sub {
  display: block;
  color: #202321;
  font-size: 27rpx;
  line-height: 1.6;
  margin-bottom: 34rpx;
}

.center { text-align: center; }
.block { display: block; }
.mini-caption { display: block; margin-top: 5rpx; color: #202321; font-size: 21rpx; line-height: 1.4; }
.mini-caption.light { color: rgba(255, 255, 255, 0.78); }
.microcopy { display: block; color: #202321; font-size: 22rpx; line-height: 1.5; }
.gold-number { color: #6f4aac; font-weight: 700; }

/* 首页 */
.home-hero {
  position: relative;
  height: 710rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #63c8b0 0%, #b7e5da 56%, #e4f1ff 100%);
}

.home-nav {
  position: relative;
  z-index: 20;
  height: 80rpx;
  padding: 0 34rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.mall-pill {
  max-width: 370rpx;
  min-height: 62rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 650;
  background: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  box-shadow: 0 8rpx 18rpx rgba(43,96,148, 0.09), inset 0 2rpx 0 rgba(255, 255, 255, 0.7);
}

.chevron-down { margin-left: 12rpx; font-size: 31rpx; }
.hero-art {
  position: relative;
  overflow: hidden;
  background: linear-gradient(140deg, #9b6de3, #b9d8fb 52%, #5da9ff);
}

.material-image { position: absolute; inset: 0; width: 100%; height: 100%; }

.hero-gallery {
  position: absolute;
  inset: 0;
}

.hero-gallery::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(36,111,98, 0.05), rgba(228,241,255, 0.1) 45%, #e4f1ff 100%);
}

.art-panel {
  position: absolute;
  top: 90rpx;
  width: 140rpx;
  height: 220rpx;
  background: linear-gradient(160deg, #202321, #ffd83d 62%, #202321);
  box-shadow: 0 14rpx 28rpx rgba(111,74,172, 0.14);
}

.panel-one { left: 120rpx; transform: rotate(-5deg); }
.panel-two { right: 122rpx; transform: rotate(4deg); }
.sculpture { position: absolute; z-index: 2; bottom: 210rpx; border-radius: 46% 54% 52% 48%; background: linear-gradient(145deg, #eee7ff, #f05aa6); box-shadow: 0 12rpx 26rpx rgba(43,96,148, 0.18); }
.sculpture-one { left: 300rpx; width: 94rpx; height: 180rpx; transform: rotate(8deg); }
.sculpture-two { right: 170rpx; width: 70rpx; height: 150rpx; background: linear-gradient(145deg, #202321, #202321); transform: rotate(-8deg); }

.hero-copy {
  position: absolute;
  z-index: 12;
  left: 34rpx;
  right: 34rpx;
  bottom: 70rpx;
}

.eyebrow {
  display: inline-flex;
  padding: 9rpx 17rpx;
  color: #fff;
  background: rgba(168,55,116, 0.88);
  border-radius: 5rpx;
  font-size: 20rpx;
  letter-spacing: 5rpx;
}

.dark-eyebrow { color: #246f62; background: rgba(205,185,238, 0.9); }
.hero-title { display: block; margin: 20rpx 0; white-space: pre-line; font-size: 53rpx; font-weight: 780; line-height: 1.22; letter-spacing: -2rpx; }
.ghost-button { width: 170rpx; height: 66rpx; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 600; background: rgba(255, 255, 255, 0.54); border: 1rpx solid rgba(255, 255, 255, 0.75); box-shadow: 0 8rpx 18rpx rgba(43,96,148, 0.08); }
.home-body { margin-top: -20rpx; padding: 0 30rpx 40rpx; position: relative; z-index: 14; }
.home-refreshing { animation: mallHomeSwap .32s cubic-bezier(.2,.72,.2,1); }
@keyframes mallHomeSwap { 0% { opacity: .28; transform: translateY(12rpx) scale(.995); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
.member-summary { min-height: 136rpx; padding: 22rpx; display: flex; align-items: center; }
.member-mark { width: 92rpx; height: 64rpx; flex: none; display: flex; align-items: center; justify-content: center; color: #246f62; font-size: 22rpx; font-weight: 700; letter-spacing: 3rpx; background: linear-gradient(145deg, #5da9ff, #6f4aac); border: 1rpx solid #246f62; border-radius: 7rpx; box-shadow: inset 0 2rpx 0 rgba(255,255,255,.58), 0 9rpx 18rpx rgba(36,111,98,.2); }
.member-mark.large { width: 110rpx; height: 76rpx; }
.member-art-seal-image { width: 104rpx; height: 74rpx; flex: none; overflow: hidden; border: 1rpx solid rgba(240,90,166,.72); border-radius: 16rpx; box-shadow: 0 9rpx 18rpx rgba(111,74,172,.13), inset 0 1rpx 0 rgba(255,255,255,.82); }
.member-copy { min-width: 0; flex: 1; margin-left: 20rpx; display: flex; flex-direction: column; }
.member-name { display: block; font-size: 32rpx; font-weight: 700; }
.member-sub { display: block; margin-top: 8rpx; color: #202321; font-size: 23rpx; }
.mini-qr { width: 56rpx; height: 56rpx; display: flex; flex-wrap: wrap; padding: 4rpx; background: #fff; }
.mini-qr-cell { width: 20%; height: 20%; background: #fff; }
.qr-dark { background: #202321 !important; }

.shortcut-row { display: flex; justify-content: space-between; margin: 28rpx 0 36rpx; }
.shortcut { width: 23%; min-height: 116rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #202321; }
.shortcut-icon-shell { width: 82rpx; height: 82rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #f05aa6; border-radius: 50%; background: linear-gradient(150deg,#e9f8f3,#cdb9ee); box-shadow: 0 7rpx 15rpx rgba(43,96,148,.1), inset 0 2rpx 3rpx rgba(255,255,255,.9); }
.shortcut-icon-image { width: 52rpx; height: 52rpx; opacity: .76; }
.shortcut-label { margin-top: 10rpx; color: #202321; font-size: 21rpx; font-weight: 560; letter-spacing: 1rpx; }
.circle-icon { width: 82rpx; height: 82rpx; margin-bottom: 13rpx; display: flex; align-items: center; justify-content: center; color: #cdb9ee; font-size: 30rpx; font-weight: 700; border: 2rpx solid #63c8b0; border-radius: 50%; background: linear-gradient(145deg, #f05aa6, #2b6094); box-shadow: 0 9rpx 18rpx rgba(43,96,148,.24), inset 0 3rpx 3rpx rgba(255,255,255,.4); }
.circle-icon.small { width: 62rpx; height: 62rpx; margin-bottom: 10rpx; font-size: 23rpx; }
.section-heading { margin: 24rpx 0 18rpx; display: flex; align-items: flex-end; justify-content: space-between; }
.section-title { display: block; font-size: 37rpx; font-weight: 730; }
.section-title.compact-title { margin: 30rpx 0 16rpx; font-size: 29rpx; }
.section-en { display: block; margin-top: 4rpx; color: #202321; font-size: 20rpx; }
.text-link { color: #2b6094; font-size: 23rpx; font-weight: 650; }
.home-module { margin-top: 22rpx; }
.home-coupon-teaser { position: relative; min-height: 150rpx; margin-bottom: 8rpx; padding: 16rpx 0 16rpx 16rpx; display: flex; align-items: center; overflow: hidden; border: 1rpx solid rgba(36,111,98,.6); border-radius: 24rpx; background: linear-gradient(118deg,#e9f8f3 0%,#cdb9ee 64%,#5da9ff 100%); box-shadow: 0 13rpx 27rpx rgba(36,111,98,.13), inset 0 2rpx 2rpx rgba(255,255,255,.86); }
.home-coupon-teaser::before, .home-coupon-teaser::after { content: ""; position: absolute; right: 103rpx; z-index: 2; width: 20rpx; height: 20rpx; border-radius: 50%; background: #e4f1ff; }
.home-coupon-teaser::before { top: -10rpx; }
.home-coupon-teaser::after { bottom: -10rpx; }
.home-coupon-image { width: 118rpx; height: 118rpx; flex: none; border: 1rpx solid rgba(255,255,255,.72); border-radius: 18rpx; box-shadow: 0 8rpx 16rpx rgba(43,96,148,.14); }
.home-coupon-copy { min-width: 0; flex: 1; padding: 0 18rpx; display: flex; flex-direction: column; }
.home-coupon-meta { display: flex; align-items: center; color: #2b6094; font-size: 18rpx; }
.home-coupon-badge { margin-right: 10rpx; padding: 4rpx 10rpx; color: #e4f1ff; border-radius: 999rpx; background: linear-gradient(145deg,#2b6094,#6f4aac); font-weight: 650; }
.home-coupon-title { margin-top: 9rpx; overflow: hidden; color: #6f4aac; font-size: 26rpx; font-weight: 720; text-overflow: ellipsis; white-space: nowrap; }
.home-coupon-note { margin-top: 6rpx; overflow: hidden; color: #a83774; font-size: 19rpx; text-overflow: ellipsis; white-space: nowrap; }
.home-coupon-action { width: 104rpx; align-self: stretch; flex: none; display: flex; align-items: center; justify-content: center; color: #246f62; border-left: 1rpx dashed rgba(43,96,148,.44); font-size: 23rpx; font-weight: 720; }
.home-coupon-arrow { margin-left: 5rpx; font-size: 32rpx; }
.activity-banner { position: relative; height: 228rpx; overflow: hidden; border: 1rpx solid rgba(99,200,176,.5); border-radius: 28rpx; box-shadow: 0 15rpx 30rpx rgba(43,96,148,.14); }
.activity-banner-image { position: absolute; inset: 0; width: 100%; height: 100%; }
.activity-banner-shade { position: absolute; inset: 0; background: linear-gradient(90deg,rgba(43,96,148,.82) 0%,rgba(36,111,98,.54) 56%,rgba(36,111,98,.08) 100%); }
.activity-banner-sunset .activity-banner-shade { background: linear-gradient(90deg,rgba(36,111,98,.84),rgba(43,96,148,.48) 64%,rgba(43,96,148,.08)); }
.activity-banner-garden .activity-banner-shade { background: linear-gradient(90deg,rgba(28,50,43,.84),rgba(44,69,58,.48) 64%,rgba(44,69,58,.08)); }
.activity-banner-copy { position: absolute; z-index: 2; left: 28rpx; right: 80rpx; top: 25rpx; display: flex; flex-direction: column; color: #e9f8f3; }
.activity-banner-kicker { align-self: flex-start; padding: 5rpx 11rpx; color: #2b6094; border-radius: 999rpx; background: linear-gradient(135deg,#5da9ff,#9b6de3); font-size: 17rpx; font-weight: 680; letter-spacing: 2rpx; }
.activity-banner-title { margin-top: 17rpx; font-size: 31rpx; font-weight: 740; line-height: 1.25; text-shadow: 0 3rpx 8rpx rgba(0,0,0,.2); }
.activity-banner-note { margin-top: 10rpx; color: rgba(233,248,243,.78); font-size: 19rpx; }
.activity-banner-arrow { position: absolute; z-index: 2; right: 23rpx; bottom: 23rpx; height: 46rpx; padding: 0 16rpx; display: flex; align-items: center; justify-content: center; color: #ffe5f2; border: 1rpx solid rgba(255,229,242,.5); border-radius: 999rpx; background: rgba(43,96,148,.38); backdrop-filter: blur(8px); font-size: 17rpx; }
.activity-banner-arrow text:last-child { margin-left: 7rpx; font-size: 25rpx; line-height: 1; }
.inspiration-scroll { width: 100%; white-space: nowrap; }
.inspiration-card { width: 300rpx; margin-right: 18rpx; display: inline-flex; flex-direction: column; vertical-align: top; overflow: hidden; border-radius: 22rpx; background: #eee7ff; box-shadow: 0 12rpx 24rpx rgba(168,55,116, 0.08); }
.thumb { width: 100%; height: 190rpx; display: block; background: #ffd83d; }
.art-thumb { background: linear-gradient(140deg, #246f62, #5da9ff); }
.book-thumb { background: linear-gradient(140deg, #2b6094, #9b6de3); }
.mall-thumb { background: linear-gradient(140deg, #8a9a96, #c9d3cc); }
.card-title { display: block; padding: 16rpx 16rpx 0; font-size: 26rpx; font-weight: 650; }
.card-caption { display: block; padding: 7rpx 16rpx 18rpx; color: #202321; font-size: 20rpx; }
.wide-benefit { min-height: 170rpx; padding: 24rpx; display: flex; align-items: center; justify-content: space-between; }
.benefit-title { display: block; margin-top: 12rpx; font-size: 31rpx; font-weight: 700; }
.benefit-sub { display: block; margin-top: 8rpx; color: #202321; font-size: 21rpx; }
.benefit-orb { width: 100rpx; height: 100rpx; display: flex; align-items: center; justify-content: center; color: #fff; border-radius: 50%; font-size: 36rpx; font-weight: 700; background: linear-gradient(145deg, #5da9ff, #a83774); box-shadow: 0 12rpx 24rpx rgba(111,74,172, 0.24), inset 0 3rpx 4rpx rgba(255,255,255,.32); }

/* 登录 */
.login-page { text-align: center; padding-top: 40rpx; }
.login-visual { position: relative; height: 350rpx; margin-bottom: 28rpx; overflow: hidden; border-radius: 42rpx; background: #b9d8fb; box-shadow: inset 0 2rpx 0 rgba(255,255,255,.8), 0 18rpx 36rpx rgba(43,96,148,.1); }
.login-visual::after { content: ""; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,.12), rgba(168,55,116,.18)); }
.coastal-orb { position: absolute; border-radius: 50%; filter: blur(1rpx); }
.orb-a { width: 260rpx; height: 260rpx; left: -40rpx; bottom: -70rpx; background: rgba(255,255,255,.55); }
.orb-b { width: 200rpx; height: 200rpx; right: 24rpx; top: 34rpx; background: linear-gradient(145deg, #c7d0ca, #b7e5da); }
.floating-card { position: absolute; z-index: 2; left: 50%; top: 50%; width: 290rpx; height: 170rpx; transform: translate(-50%, -45%) rotate(-8deg); padding: 34rpx; display: flex; flex-direction: column; align-items: flex-start; justify-content: space-between; color: #a83774; font-size: 16rpx; letter-spacing: 6rpx; border-radius: 20rpx; background: linear-gradient(145deg, rgba(244,181,213,.94), rgba(43,96,148,.94)); box-shadow: 0 24rpx 40rpx rgba(111,74,172,.22), inset 0 3rpx 3rpx rgba(255,255,255,.45); }
.floating-card-logo { font-size: 38rpx; font-weight: 700; letter-spacing: 4rpx; }
.agreement { margin: 26rpx 10rpx; display: flex; align-items: flex-start; text-align: left; color: #202321; font-size: 21rpx; line-height: 1.5; }
.check-dot { width: 28rpx; height: 28rpx; flex: none; margin: 2rpx 13rpx 0 0; border: 2rpx solid #9b6de3; border-radius: 50%; background: #fff; }
.muted-link { margin: 28rpx auto; color: #202321; font-size: 23rpx; text-align: center; }

/* 会员、积分、权益 */
.membership-card { position: relative; height: 270rpx; padding: 34rpx; overflow: hidden; display: flex; flex-direction: column; align-items: flex-start; color: #ffe5f2; background: #6f4aac; border: 1rpx solid #9b6de3; box-shadow: 0 18rpx 34rpx rgba(43,96,148,.2); }
.membership-card-art { position: absolute; inset: 0; width: 100%; height: 100%; }
.membership-card-shade { position: absolute; inset: 0; background: linear-gradient(90deg,rgba(32,35,33,.2),rgba(32,35,33,.04) 58%,rgba(32,35,33,.08)); pointer-events: none; }
.membership-logo, .membership-level, .membership-id { position: relative; z-index: 2; text-shadow: 0 3rpx 8rpx rgba(0,0,0,.28); }
.membership-logo { color: #9b6de3; font-size: 23rpx; letter-spacing: 5rpx; }
.membership-level { margin-top: 50rpx; color: #e9f8f3; font-size: 42rpx; font-weight: 760; }
.membership-id { margin-top: 10rpx; color: rgba(255,229,242,.78); font-size: 22rpx; }
.qr-panel { margin-top: 22rpx; padding: 24rpx; }
.panel-title { display: block; font-size: 28rpx; font-weight: 650; }
.qr-code { width: 224rpx; height: 224rpx; margin: 20rpx auto; padding: 15rpx; display: flex; flex-wrap: wrap; background: #fff; border: 1rpx solid #f4b5d5; }
.qr-cell { width: 4.7619%; height: 4.7619%; background: #fff; }
.stats-card { margin-top: 20rpx; padding: 26rpx; display: flex; align-items: center; justify-content: space-around; }
.stat { flex: 1; text-align: center; }
.stat-label { display: block; color: #202321; font-size: 22rpx; }
.stat-value { display: block; margin-top: 6rpx; font-size: 38rpx; color: #2b6094; font-family: Georgia, serif; }
.stat-divider { width: 1rpx; height: 64rpx; margin: 0 24rpx; background: #ffd83d; }
.dual-actions { display: flex; margin: 20rpx -8rpx 0; }
.outline-action, .large-action { flex: 1; min-height: 82rpx; margin: 0 8rpx; display: flex; align-items: center; justify-content: center; color: #6f4aac; border: 1rpx solid #cdb9ee; border-radius: 999rpx; background: linear-gradient(145deg, #eee7ff, #e4f1ff); box-shadow: 0 8rpx 18rpx rgba(36,111,98,.07), inset 0 2rpx 2rpx rgba(255,255,255,.9); font-size: 24rpx; font-weight: 600; }
.large-action { min-height: 104rpx; border-radius: 24rpx; font-size: 26rpx; }
.action-icon { margin-right: 12rpx; font-weight: 760; }
.compact-title { margin-top: 30rpx; }
.mini-benefit-row { display: flex; margin: 0 -8rpx; }
.mini-benefit { flex: 1; min-width: 0; min-height: 116rpx; margin: 0 8rpx; padding: 16rpx; display: flex; align-items: center; border-radius: 20rpx; background: linear-gradient(145deg, #f4b5d5, #eee7ff); border: 1rpx solid #ffd83d; }
.mini-benefit-icon { width: 54rpx; height: 54rpx; flex: none; margin-right: 12rpx; display: flex; align-items: center; justify-content: center; color: #246f62; border-radius: 50%; background: #cdb9ee; }
.member-exclusive { margin-top: 18rpx; }
.outline-action, .large-action, .mini-benefit, .facility { position: relative; overflow: hidden; }
.outline-action::after, .large-action::after, .mini-benefit::after, .facility::after { content: ""; position: absolute; top: 2rpx; right: 2rpx; width: 54%; height: 50%; border-top: 2rpx solid rgba(240,90,166,.98); border-right: 2rpx solid rgba(240,90,166,.98); border-radius: 0 20rpx 0 0; pointer-events: none; }
.outline-action::after { border-radius: 0 999rpx 0 0; }
.growth-hero { min-height: 210rpx; padding: 30rpx; display: flex; align-items: center; justify-content: space-between; background: linear-gradient(135deg, #f4b5d5, #9b6de3); }
.growth-value { display: block; margin-top: 20rpx; color: #a83774; font-size: 33rpx; }
