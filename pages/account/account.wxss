.route-loading {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #7f7668;
  background: #fdf9f1;
  font-size: 26rpx;
}

.route-mark {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fffdf9;
  background: linear-gradient(145deg, #cba65c, #8f651f);
  box-shadow: 0 16rpx 30rpx rgba(108, 75, 23, 0.2);
  font-size: 38rpx;
}
